/* ===== 登录页 ===== */
.login-section { display: flex; flex-direction: column; align-items: center; padding-top: 260rpx; }
.login-icon {
  width: 80rpx; height: 80rpx; margin-bottom: 28rpx;
  background: #0a84ff; border-radius: 22rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 40rpx;
}
.login-title { font-size: 36rpx; font-weight: 700; margin-bottom: 10rpx; }
.login-sub { font-size: 28rpx; color: rgba(255,255,255,0.4); margin-bottom: 60rpx; }
.nickname-input {
  width: 560rpx; height: 90rpx;
  background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 14rpx; color: #fff; padding: 0 30rpx; margin-bottom: 24rpx; font-size: 30rpx;
}
.btn-login {
  width: 560rpx; height: 90rpx; background: #0a84ff; color: #fff;
  border-radius: 14rpx; font-size: 32rpx; font-weight: 600;
  display: flex; align-items: center; justify-content: center;
}

/* 最近使用 */
.recent-section { margin-top: 80rpx; text-align: center; }
.recent-title { font-size: 22rpx; color: rgba(255,255,255,0.3); margin-bottom: 20rpx; }
.recent-list { display: flex; flex-wrap: wrap; gap: 14rpx; justify-content: center; }
.recent-tag {
  padding: 16rpx 36rpx; background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.08); border-radius: 28rpx;
  font-size: 26rpx; color: rgba(255,255,255,0.55);
}

/* ===== 首页 ===== */
.home-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32rpx; }
.home-greeting { font-size: 40rpx; font-weight: 700; }
.home-greeting .arrow { font-size: 20rpx; color: rgba(255,255,255,0.4); margin-left: 4rpx; }
.btn-create-room {
  background: #0a84ff; color: #fff; border-radius: 28rpx;
  font-size: 26rpx; font-weight: 600; height: 64rpx; padding: 0 28rpx;
  display: flex; align-items: center; justify-content: center;
}

/* 切换面板 */
.switch-panel {
  background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 14rpx; padding: 24rpx; margin-bottom: 28rpx;
}
.switch-label { font-size: 24rpx; color: rgba(255,255,255,0.3); margin-bottom: 16rpx; }
.switch-item { padding: 22rpx 0; font-size: 30rpx; border-bottom: 1rpx solid rgba(255,255,255,0.06); display: flex; justify-content: space-between; align-items: center; }
.switch-item:last-child { border-bottom: none; }
.switch-item .cur { font-size: 24rpx; color: rgba(255,255,255,0.3); }
.switch-actions { display: flex; gap: 16rpx; margin-top: 20rpx; }
.btn-switch-out { flex: 1; height: 64rpx; border: 1rpx solid #ff3b30; color: #ff3b30; background: transparent; border-radius: 14rpx; font-size: 26rpx; display: flex; align-items: center; justify-content: center; }
.btn-switch-cancel { flex: 1; height: 64rpx; background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.5); border-radius: 14rpx; font-size: 26rpx; display: flex; align-items: center; justify-content: center; }

/* 加入 */
.join-section { margin-bottom: 28rpx; }
.join-label { font-size: 22rpx; color: rgba(255,255,255,0.35); margin-bottom: 14rpx; letter-spacing: 0.5rpx; }
.join-body { display: flex; gap: 14rpx; }
.code-input {
  flex: 1; height: 82rpx;
  background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 12rpx; color: #fff; padding: 0 20rpx;
  font-size: 36rpx; text-align: center; letter-spacing: 12rpx; font-weight: 600;
}
.btn-join-code { background: #0a84ff; color: #fff; border-radius: 12rpx; font-size: 26rpx; height: 82rpx; padding: 0 30rpx; display: flex; align-items: center; justify-content: center; }

/* 房间列表 */
.room-list-title { font-size: 22rpx; color: rgba(255,255,255,0.35); margin-bottom: 16rpx; letter-spacing: 0.5rpx; }
.room-empty { text-align: center; color: rgba(255,255,255,0.25); padding: 100rpx 0; font-size: 26rpx; }
.room-item {
  display: flex; align-items: center; padding: 24rpx;
  background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 14rpx; margin-bottom: 14rpx;
}
.room-item .info { flex: 1; }
.room-item .name { font-size: 30rpx; font-weight: 600; margin-bottom: 4rpx; }
.room-item .code { font-size: 24rpx; color: rgba(255,255,255,0.35); }
.room-item .status-tag { font-size: 22rpx; padding: 6rpx 18rpx; border-radius: 20rpx; margin-right: 14rpx; }
.status-waiting { color: #30d158; background: rgba(48,209,88,0.12); }
.status-active { color: #ff9f0a; background: rgba(255,159,10,0.12); }
.btn-join-room { height: 54rpx; padding: 0 22rpx; background: #0a84ff; color: #fff; border-radius: 14rpx; font-size: 24rpx; display: flex; align-items: center; justify-content: center; }
