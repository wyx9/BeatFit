.container { padding: 30rpx; }
.section { margin-bottom: 30rpx; }
.label { font-size: 28rpx; color: #ccc; margin-bottom: 16rpx; }
.name-input {
  height: 80rpx; background: #1a1a2e; border: 2rpx solid #333;
  border-radius: 16rpx; color: #fff; padding: 0 30rpx; font-size: 30rpx;
}

/* 分类标签 */
.cat-scroll { display: flex; white-space: nowrap; margin-bottom: 24rpx; }
.cat-tab {
  display: inline-block; padding: 12rpx 28rpx; margin-right: 12rpx;
  background: #1a1a2e; border: 2rpx solid #333; border-radius: 30rpx;
  font-size: 26rpx; color: #999;
}
.cat-tab.active { background: #e94560; color: #fff; border-color: #e94560; }

/* 动作网格 */
.ex-grid { display: flex; flex-wrap: wrap; margin-bottom: 20rpx; }
.ex-preset-card {
  width: calc(50% - 10rpx); margin: 0 20rpx 20rpx 0; padding: 20rpx 16rpx;
  background: #1a1a2e; border: 2rpx solid #333; border-radius: 16rpx;
  text-align: center; position: relative; box-sizing: border-box;
}
.ex-preset-card:nth-child(2n) { margin-right: 0; }
.ex-preset-card.selected { border-color: #e94560; background: rgba(233,69,96,0.08); }
.ex-icon { font-size: 40rpx; margin-bottom: 8rpx; }
.ex-name { font-size: 24rpx; color: #fff; margin-bottom: 4rpx; }
.ex-time { font-size: 20rpx; color: #999; }
.ex-check-on {
  position: absolute; top: 8rpx; right: 8rpx;
  width: 32rpx; height: 32rpx; background: #e94560; border-radius: 50%;
  color: #fff; font-size: 20rpx; text-align: center; line-height: 32rpx;
}

/* 已选 */
.chip-wrap { display: flex; flex-wrap: wrap; gap: 12rpx; }
.chip {
  padding: 8rpx 16rpx; background: rgba(233,69,96,0.1);
  border: 2rpx solid rgba(233,69,96,0.2); border-radius: 24rpx;
  font-size: 22rpx; color: #ccc; display: flex; align-items: center; gap: 8rpx;
}
.chip-close { color: #999; font-weight: bold; font-size: 26rpx; }

/* 按钮 */
.btn-create {
  background: #e94560; color: #fff; border-radius: 40rpx;
  font-size: 32rpx; height: 85rpx; line-height: 85rpx; margin-top: 30rpx;
}
