.section { margin-bottom: 28rpx; }
.label { font-size: 26rpx; color: rgba(255,255,255,0.55); margin-bottom: 14rpx; }
.name-input { height: 88rpx; background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 14rpx; color: #fff; padding: 0 24rpx; font-size: 30rpx; }

/* 分类标签 */
.cat-scroll { display: flex; white-space: nowrap; margin-bottom: 24rpx; }
.cat-tab { display: inline-flex; align-items: center; justify-content: center; padding: 14rpx 32rpx; margin-right: 12rpx; background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 28rpx; font-size: 26rpx; color: rgba(255,255,255,0.55); }
.cat-tab.active { background: #0a84ff; color: #fff; border-color: #0a84ff; }

/* 动作网格 */
.ex-grid { display: flex; flex-wrap: wrap; margin-bottom: 12rpx; }
.ex-preset-card { width: calc(50% - 10rpx); margin: 0 20rpx 20rpx 0; padding: 22rpx 16rpx; background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 14rpx; text-align: center; position: relative; box-sizing: border-box; }
.ex-preset-card:nth-child(2n) { margin-right: 0; }
.ex-preset-card.selected { border-color: #0a84ff; background: rgba(10,132,255,0.08); }
.ex-icon { font-size: 44rpx; margin-bottom: 8rpx; }
.ex-name { font-size: 26rpx; color: #fff; margin-bottom: 6rpx; font-weight: 500; }
.ex-time { font-size: 20rpx; color: rgba(255,255,255,0.3); }
.ex-check-on { position: absolute; top: 10rpx; right: 10rpx; width: 34rpx; height: 34rpx; background: #0a84ff; border-radius: 50%; color: #fff; font-size: 20rpx; display: flex; align-items: center; justify-content: center; }

/* 自定义动作 */
.custom-ex-section { margin-bottom: 24rpx; padding: 20rpx; background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.06); border-radius: 14rpx; }
.custom-row { display: flex; align-items: center; gap: 10rpx; margin-bottom: 12rpx; }
.custom-inp { flex: 1; height: 68rpx; background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 10rpx; color: #fff; padding: 0 16rpx; font-size: 26rpx; }
.custom-inp-sm { width: 120rpx; height: 68rpx; background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 10rpx; color: #fff; padding: 0 8rpx; font-size: 24rpx; text-align: center; }
.custom-label { font-size: 22rpx; color: rgba(255,255,255,0.3); flex-shrink: 0; }
.btn-add-custom { margin-left: 4rpx; padding: 0 20rpx; height: 68rpx; display: flex; align-items: center; justify-content: center; background: #0a84ff; color: #fff; border-radius: 10rpx; font-size: 24rpx; }

/* 已选动作 */
.sel-card { background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 14rpx; padding: 22rpx; margin-bottom: 14rpx; }
.sel-hdr { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; font-size: 28rpx; color: #fff; font-weight: 600; }
.sel-del { font-size: 24rpx; color: rgba(255,255,255,0.3); }
.sel-fields { display: flex; gap: 10rpx; }
.sel-fld { flex: 1; text-align: center; }
.sel-fld-lbl { display: block; font-size: 20rpx; color: rgba(255,255,255,0.3); margin-bottom: 6rpx; }
.sel-fld-inp { width: 100%; height: 58rpx; text-align: center; background: rgba(255,255,255,0.08); border: 1rpx solid rgba(255,255,255,0.1); border-radius: 8rpx; color: #fff; font-size: 24rpx; }

/* 按钮 */
.btn-create { background: #0a84ff; color: #fff; border-radius: 14rpx; font-size: 32rpx; font-weight: 600; height: 88rpx; display: flex; align-items: center; justify-content: center; margin-top: 16rpx; }
.btn-back { background: transparent; color: rgba(255,255,255,0.3); font-size: 26rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; }
