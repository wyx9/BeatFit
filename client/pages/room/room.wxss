/* 房间头 */
.waiting-header { text-align: center; margin-bottom: 36rpx; }
.waiting-room-name { font-size: 44rpx; font-weight: 700; margin-bottom: 24rpx; }
.code-display {
  display: inline-block; padding: 28rpx 40rpx;
  background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 14rpx;
}
.code-label { font-size: 20rpx; color: rgba(255,255,255,0.35); display: block; margin-bottom: 8rpx; letter-spacing: 0.5rpx; }
.code-val { font-size: 56rpx; font-weight: 800; color: #0a84ff; letter-spacing: 16rpx; }

.card { background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 14rpx; padding: 24rpx; margin-bottom: 20rpx; }
.card-title { font-size: 22rpx; color: rgba(255,255,255,0.35); margin-bottom: 14rpx; letter-spacing: 0.5rpx; }

/* 动作 */
.ex-row { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.06); }
.ex-row:last-child { border-bottom: none; }
.ex-num { width: 44rpx; height: 44rpx; background: rgba(10,132,255,0.12); color: #0a84ff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 22rpx; font-weight: 700; margin-right: 18rpx; flex-shrink: 0; }
.ex-name { flex: 1; font-size: 28rpx; }
.ex-dur { font-size: 24rpx; color: #30d158; font-weight: 500; }

/* 成员 */
.member-row { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.06); }
.member-row:last-child { border-bottom: none; }
.member-avatar { width: 56rpx; height: 56rpx; background: #0a84ff; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 24rpx; font-weight: 600; margin-right: 18rpx; }
.member-name { flex: 1; font-size: 28rpx; }
.owner-badge { font-size: 20rpx; color: #0a84ff; padding: 4rpx 14rpx; background: rgba(10,132,255,0.12); border-radius: 14rpx; }

/* 按钮区 */
.room-actions { display: flex; gap: 14rpx; margin-top: 40rpx; }
.btn-leave-room { flex: 1; height: 88rpx; background: transparent; border: 1rpx solid rgba(255,255,255,0.12); color: rgba(255,255,255,0.5); border-radius: 14rpx; font-size: 28rpx; display: flex; align-items: center; justify-content: center; }
.btn-start-train { flex: 2; height: 88rpx; background: #0a84ff; color: #fff; border-radius: 14rpx; font-size: 30rpx; font-weight: 600; display: flex; align-items: center; justify-content: center; }
.wait-tip { flex: 2; text-align: center; color: rgba(255,255,255,0.3); font-size: 28rpx; display: flex; align-items: center; justify-content: center; }
