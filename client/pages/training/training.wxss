.container {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
}

/* Progress */
.progress-bar {
  width: 100%;
  height: 6rpx;
  background: #1a1a2e;
  border-radius: 3rpx;
  overflow: hidden;
  margin-bottom: 10rpx;
}
.progress-fill {
  height: 100%;
  background: #e94560;
  border-radius: 3rpx;
  transition: width 0.3s;
}
.progress-text {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 40rpx;
}

/* Timer */
.timer-section {
  margin-bottom: 50rpx;
}
.timer-ring {
  width: 320rpx;
  height: 320rpx;
  border: 8rpx solid #e94560;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.timer-inner {
  text-align: center;
}
.timer-text {
  font-size: 120rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  line-height: 1;
}
.timer-unit {
  font-size: 28rpx;
  color: #999;
}

/* Current exercise */
.current-ex {
  text-align: center;
  margin-bottom: 30rpx;
  background: #1a1a2e;
  border-radius: 20rpx;
  padding: 30rpx 60rpx;
  width: 100%;
  box-sizing: border-box;
}
.ex-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

/* 终止训练按钮 */
.btn-terminate {
  margin: 0 auto 20rpx;
  width: 240rpx;
  height: 56rpx;
  line-height: 56rpx;
  background: transparent;
  border: 2rpx solid #555;
  border-radius: 28rpx;
  color: #999;
  font-size: 24rpx;
}
.ex-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}
.ex-duration {
  font-size: 26rpx;
  color: #4ecca3;
}

/* Next exercise */
.next-ex {
  text-align: center;
  padding: 20rpx 30rpx;
  color: #666;
  font-size: 26rpx;
  margin-bottom: 30rpx;
}
.next-name {
  color: #ccc;
  font-weight: bold;
}
.next-dur {
  color: #4ecca3;
  margin-left: 10rpx;
}

/* Completed */
.completed-section {
  width: 100%;
}
.completed-title {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 15rpx;
}
.completed-item {
  padding: 15rpx 20rpx;
  color: #4ecca3;
  font-size: 26rpx;
}
.check {
  margin-right: 12rpx;
  font-weight: bold;
}

/* Finished */
.training-finished {
  text-align: center;
  padding-top: 100rpx;
}
.finish-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}
.finish-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 15rpx;
}
.finish-subtitle {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 50rpx;
}
.completed-all {
  text-align: left;
  background: #1a1a2e;
  border-radius: 16rpx;
  padding: 25rpx 30rpx;
  margin-bottom: 50rpx;
}
.completed-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 15rpx;
}
.btn-home {
  background: #e94560;
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
  height: 80rpx;
  line-height: 80rpx;
  width: 400rpx;
}
