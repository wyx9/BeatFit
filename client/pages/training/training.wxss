.container { padding: 30rpx; display: flex; flex-direction: column; align-items: center; min-height: 100vh; }

.progress-bar { width: 100%; height: 6rpx; background: rgba(255,255,255,0.08); border-radius: 3rpx; overflow: hidden; margin-bottom: 10rpx; }
.progress-fill { height: 100%; background: #007AFF; border-radius: 3rpx; transition: width 0.5s ease; }
.progress-text { font-size: 24rpx; color: rgba(255,255,255,0.3); margin-bottom: 48rpx; }

.timer-section { margin-bottom: 52rpx; }
.timer-ring { width: 340rpx; height: 340rpx; border: 6rpx solid #007AFF; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
.timer-inner { text-align: center; }
.timer-text { font-size: 120rpx; font-weight: 800; color: #fff; display: block; line-height: 1; letter-spacing: -4rpx; }
.timer-unit { font-size: 28rpx; color: rgba(255,255,255,0.3); }

.current-ex { text-align: center; margin-bottom: 30rpx; background: rgba(255,255,255,0.05); border: 2rpx solid rgba(255,255,255,0.08); border-radius: 20rpx; padding: 28rpx 48rpx; width: 100%; box-sizing: border-box; }
.ex-label { font-size: 22rpx; color: rgba(255,255,255,0.3); margin-bottom: 8rpx; letter-spacing: 1rpx; }
.ex-title { font-size: 44rpx; font-weight: 700; color: #fff; margin-bottom: 8rpx; }
.ex-duration { font-size: 26rpx; color: #22c55e; }

.next-ex { text-align: center; padding: 20rpx; color: rgba(255,255,255,0.3); font-size: 26rpx; margin-bottom: 30rpx; }
.next-label { color: rgba(255,255,255,0.3); }
.next-name { color: rgba(255,255,255,0.55); font-weight: 600; }
.next-dur { color: #22c55e; margin-left: 8rpx; }

.completed-section { width: 100%; }
.completed-title { font-size: 22rpx; color: rgba(255,255,255,0.3); margin-bottom: 16rpx; letter-spacing: 1rpx; }
.completed-item { padding: 16rpx 20rpx; color: #22c55e; font-size: 26rpx; }
.check { margin-right: 12rpx; font-weight: 700; }

.btn-terminate { margin: 0 auto 24rpx; width: 240rpx; height: 60rpx; background: transparent; border: 2rpx solid rgba(255,255,255,0.12); color: rgba(255,255,255,0.55); border-radius: 30rpx; font-size: 24rpx; display: flex; align-items: center; justify-content: center; }

.training-finished { text-align: center; padding-top: 120rpx; }
.finish-icon { font-size: 120rpx; margin-bottom: 30rpx; }
.finish-title { font-size: 52rpx; font-weight: 700; color: #fff; margin-bottom: 16rpx; }
.finish-subtitle { font-size: 28rpx; color: rgba(255,255,255,0.3); margin-bottom: 60rpx; }
.completed-all { text-align: left; background: rgba(255,255,255,0.05); border: 2rpx solid rgba(255,255,255,0.08); border-radius: 20rpx; padding: 24rpx; margin-bottom: 60rpx; }
.completed-label { font-size: 22rpx; color: rgba(255,255,255,0.3); margin-bottom: 16rpx; }
.btn-home { background: #007AFF; color: #fff; border-radius: 44rpx; font-size: 30rpx; font-weight: 600; height: 88rpx; width: 420rpx; display: flex; align-items: center; justify-content: center; }
