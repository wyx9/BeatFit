page {
  background-color: #000;
  color: #fff;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Segoe UI', sans-serif;
  -webkit-font-smoothing: antialiased;
}

.container { padding: 28rpx 30rpx 60rpx; min-height: 100vh; }

/* 卡片 */
.card {
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 14rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

/* 标签文本 */
.section-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.35);
  margin-bottom: 16rpx;
  letter-spacing: 0.5rpx;
}

/* 小标签 */
.tag { display: inline-flex; align-items: center; padding: 6rpx 20rpx; border-radius: 24rpx; font-size: 22rpx; font-weight: 500; }
.tag-green { color: #30d158; background: rgba(48,209,88,0.12); }
.tag-blue { color: #0a84ff; background: rgba(10,132,255,0.12); }
