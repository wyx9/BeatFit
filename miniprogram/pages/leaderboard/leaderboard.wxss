/* ===== 排行榜页面样式 - 1:1 还原 _1/code.html ===== */

/* === Top AppBar === */
.header {
  position: fixed;
  top: 0;
  width: 100%;
  z-index: 50;
  background: transparent;
}

.header-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 48rpx;
  max-width: 1280rpx;
  margin: 0 auto;
  /* Status bar height handled by WeChat */
}

.header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.avatar-sm {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #f1f5f9;
}

.ring-primary {
  box-shadow: 0 0 0 4rpx rgba(34, 197, 94, 0.1);
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-placeholder-sm {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #22c55e, #16a34a);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-initial-sm {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #131313;
  letter-spacing: -0.5rpx;
}

.icon {
  width: 48rpx;
  height: 48rpx;
}

.icon-settings {
  opacity: 0.6;
}

/* === Main Content === */
.main {
  padding-top: 176rpx;   /* header height + status bar */
  padding-bottom: 256rpx; /* bottom nav space */
  padding-left: 48rpx;
  padding-right: 48rpx;
  max-width: 640rpx;
  margin: 0 auto;
}

/* === Hero Section === */
.hero {
  margin-bottom: 80rpx;
}

.hero-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #131313;
  margin-bottom: 4rpx;
}

.hero-subtitle {
  display: block;
  font-size: 28rpx;
  color: #454747;
  margin-bottom: 48rpx;
}

/* === Podium === */
.podium {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  justify-content: space-between;
  gap: 24rpx;
  height: 512rpx;
  margin-bottom: 48rpx;
}

.podium-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}

.podium-avatar-wrap {
  position: relative;
  margin-bottom: 16rpx;
}

.podium-avatar {
  border-radius: 50%;
  padding: 4rpx;
  background: #fff;
  overflow: hidden;
}

.podium-avatar-1st {
  width: 160rpx;
  height: 160rpx;
  border: 8rpx solid var(--color-primary);
  box-shadow: 0 4rpx 24rpx rgba(34, 197, 94, 0.2);
}

.podium-avatar-2nd {
  width: 128rpx;
  height: 128rpx;
  border: 4rpx solid #f1f5f9;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.podium-avatar-3rd {
  width: 128rpx;
  height: 128rpx;
  border: 4rpx solid #f1f5f9;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.podium-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.rank-badge {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  border-radius: 50%;
  color: #fff;
}

.rank-badge-1 {
  width: 48rpx;
  height: 48rpx;
  font-size: 24rpx;
  background: var(--color-primary);
  box-shadow: 0 4rpx 16rpx rgba(34, 197, 94, 0.3);
}

.rank-badge-2 {
  width: 40rpx;
  height: 40rpx;
  font-size: 20rpx;
  background: #94a3b8;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.rank-badge-3 {
  width: 40rpx;
  height: 40rpx;
  font-size: 20rpx;
  background: #fb923c;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.crown-icon {
  position: absolute;
  top: -52rpx;
  left: 50%;
  transform: translateX(-50%);
}

.icon-crown {
  width: 60rpx;
  height: 60rpx;
}

/* Podium Bars */
.podium-bar {
  width: 100%;
  border-top-left-radius: 16rpx;
  border-top-right-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  border-left: 2rpx solid rgba(226, 232, 240, 0.2);
  border-right: 2rpx solid rgba(226, 232, 240, 0.2);
  border-top: 2rpx solid rgba(226, 232, 240, 0.2);
}

.podium-bar-1st {
  height: 256rpx;
  background: linear-gradient(180deg, rgba(34, 197, 94, 0.1) 0%, rgba(34, 197, 94, 0.02) 100%);
  border-color: rgba(34, 197, 94, 0.2);
}

.podium-bar-2nd {
  height: 192rpx;
  background: var(--color-surface-variant);
}

.podium-bar-3rd {
  height: 160rpx;
  background: var(--color-surface-variant);
}

.podium-name {
  font-size: 24rpx;
  font-weight: 500;
  color: #454747;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
}

.podium-name-1st {
  color: var(--color-primary);
  font-weight: 700;
}

.podium-value-wrap {
  display: flex;
  align-items: baseline;
  gap: 2rpx;
}

.podium-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #131313;
}

.podium-value-1st {
  font-size: 48rpx;
}

.podium-unit {
  font-size: 20rpx;
  font-weight: 400;
  color: #454747;
}

/* === Tab Switcher === */
.tab-bar {
  display: flex;
  gap: 8rpx;
  padding: 12rpx;
  background: var(--color-surface-variant);
  border-radius: 9999rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.3);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  margin-bottom: 48rpx;
  position: sticky;
  top: 160rpx;
  z-index: 40;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 9999rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #454747;
  transition: all 0.3s;
}

.tab-active {
  background: var(--color-primary);
  color: #ffffff;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(34, 197, 94, 0.2);
}

/* === Rankings List === */
.ranking-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  gap: 32rpx;
  padding: 32rpx;
  background: #fff;
  border: 1rpx solid rgba(226, 232, 240, 0.3);
  border-radius: 32rpx;
  transition: all 0.2s;
}

.rank-item-pressed {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.rank-num {
  width: 64rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #cbd5e1;
}

.rank-avatar-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  overflow: hidden;
  box-shadow: 0 0 0 4rpx rgba(248, 249, 255, 1);
}

.rank-avatar-img {
  width: 100%;
  height: 100%;
}

.rank-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.rank-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #131313;
}

.rank-level {
  font-size: 22rpx;
  font-weight: 500;
  color: #454747;
}

.rank-stats {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.rank-stats-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #131313;
}

.rank-stats-unit {
  font-size: 24rpx;
  font-weight: 400;
  color: #454747;
}

/* === Bottom Navigation Bar === */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  z-index: 50;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 32rpx 32rpx calc(64rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-top: 1rpx solid rgba(226, 232, 240, 0.3);
  box-shadow: 0 -16rpx 60rpx rgba(0, 0, 0, 0.02);
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 48rpx;
  color: #454747;
  transition: all 0.2s;
}

.nav-active {
  color: var(--color-primary);
}

.nav-icon-wrap {
  position: relative;
}

.nav-icon {
  width: 48rpx;
  height: 48rpx;
}

.nav-dot {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 12rpx;
  height: 12rpx;
  background: var(--color-primary);
  border-radius: 50%;
  border: 4rpx solid #fff;
}

.nav-label {
  font-size: 22rpx;
  font-weight: 700;
  margin-top: 2rpx;
}

.nav-label-active {
  color: var(--color-primary);
}
