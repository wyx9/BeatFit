/* ===== 创建训练房间 - 1:1 还原 _5/code.html ===== */

/* === Top AppBar === */
.header {
  position: fixed;
  top: 0;
  width: 100%;
  z-index: 50;
  background: transparent;
}

.header-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 40rpx;
  height: 128rpx;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.header-back {
  width: 48rpx;
  height: 48rpx;
}

.header-logo {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: -1rpx;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.header-notif {
  width: 48rpx;
  height: 48rpx;
  opacity: 0.7;
}

.header-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #d3e4fe;
}

.header-avatar-img {
  width: 100%;
  height: 100%;
}

/* === Main Content === */
.main {
  padding-top: 192rpx;
  padding-bottom: 256rpx;
  padding-left: 40rpx;
  padding-right: 40rpx;
  max-width: 960rpx;
  margin: 0 auto;
}

/* === Section === */
.section {
  margin-bottom: 64rpx;
}

.section-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #0b1c30;
  margin-bottom: 24rpx;
}

.section-desc {
  display: block;
  font-size: 28rpx;
  color: #3d4a3d;
  margin-top: 4rpx;
}

.section-header-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 32rpx;
}

.section-header-text {
  display: flex;
  flex-direction: column;
}

.section-header-text .section-title {
  margin-bottom: 0;
}

.section-action {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.action-icon {
  width: 36rpx;
  height: 36rpx;
}

.action-text {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--color-primary);
}

/* === Field Input === */
.field-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.field-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #3d4a3d;
  letter-spacing: 0.05em;
}

.field-input {
  width: 100%;
  height: 112rpx;
  padding: 0 48rpx;
  background: #fff;
  border: 2rpx solid rgba(188, 203, 185, 0.3);
  border-radius: 9999rpx;
  font-size: 36rpx;
  font-weight: 400;
  color: #0b1c30;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.02);
  box-sizing: border-box;
}

.field-input:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 8rpx rgba(34, 197, 94, 0.1);
}

.field-placeholder {
  color: rgba(61, 74, 61, 0.4);
  font-size: 32rpx;
}

/* === Body Part Tabs === */
.tabs-scroll {
  display: flex;
  white-space: nowrap;
  margin-bottom: 48rpx;
  padding-bottom: 16rpx;
  width: 100%;
}

.body-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 48rpx;
  border-radius: 9999rpx;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 1;
  background: #fff;
  border: 2rpx solid rgba(188, 203, 185, 0.3);
  color: #3d4a3d;
  margin-right: 16rpx;
  white-space: nowrap;
  flex-shrink: 0;
  height: 64rpx;
  box-sizing: border-box;
}

.body-tab-active {
  background: var(--color-primary);
  color: #fff;
  border-color: var(--color-primary);
  box-shadow: 0 4rpx 16rpx rgba(34, 197, 94, 0.2);
}

/* === Categories === */
.categories {
  display: flex;
  flex-direction: column;
  gap: 64rpx;
}

.category {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.category-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 2rpx solid rgba(188, 203, 185, 0.2);
  padding-bottom: 24rpx;
}

.category-title-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.category-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
  letter-spacing: 0.05em;
}

.category-title-empty {
  color: #3d4a3d;
}

.category-title-empty-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #3d4a3d;
  letter-spacing: 0.05em;
}

.category-icon {
  width: 40rpx;
  height: 40rpx;
}

.category-icon-empty {
  opacity: 0.5;
}

.category-action {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

/* === Workout Cards Grid === */
.workout-grid {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.workout-card {
  background: #fff;
  border: 2rpx solid rgba(188, 203, 185, 0.1);
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.workout-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.workout-name-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.workout-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #0b1c30;
}

.workout-tag {
  font-size: 20rpx;
  font-weight: 700;
  color: var(--color-primary);
  background: rgba(34, 197, 94, 0.1);
  padding: 4rpx 24rpx;
  border-radius: 9999rpx;
}

.workout-close {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.4;
}

.workout-inputs {
  display: flex;
  gap: 24rpx;
}

.workout-field {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.workout-label {
  font-size: 22rpx;
  font-weight: 500;
  color: #3d4a3d;
}

.workout-input {
  width: 100%;
  height: 80rpx;
  background: #e5eeff;
  border: none;
  border-radius: 24rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #0b1c30;
  padding: 0 8rpx;
  box-sizing: border-box;
}

.workout-input:focus {
  box-shadow: 0 0 0 4rpx rgba(34, 197, 94, 0.3);
}

/* === Empty State === */
.empty-state {
  border: 4rpx dashed rgba(188, 203, 185, 0.3);
  border-radius: 32rpx;
  padding: 64rpx;
  text-align: center;
  background: rgba(239, 244, 255, 0.3);
}

.empty-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #3d4a3d;
}

/* === Room Settings === */
.settings-card {
  background: #eff4ff;
  border-radius: 48rpx;
  padding: 48rpx;
  margin-bottom: 64rpx;
}

.settings-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #0b1c30;
  letter-spacing: 0.05em;
  margin-bottom: 32rpx;
}

.settings-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.chip {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #fff;
  border: 2rpx solid rgba(188, 203, 185, 0.2);
  border-radius: 9999rpx;
  padding: 16rpx 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.02);
}

.chip-icon {
  width: 36rpx;
  height: 36rpx;
}

.chip-text {
  font-size: 24rpx;
  font-weight: 500;
  color: #3d4a3d;
}

/* === Bottom Action Bar === */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  z-index: 50;
  background: rgba(248, 249, 255, 0.9);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-top: 2rpx solid rgba(188, 203, 185, 0.1);
  padding: 48rpx 40rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.bottom-bar-inner {
  max-width: 960rpx;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.btn-start {
  width: 100%;
  height: 112rpx;
  background: var(--color-primary);
  border-radius: 9999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow: 0 16rpx 48rpx rgba(34, 197, 94, 0.3);
  transition: all 0.2s;
  position: relative;
  overflow: hidden;
}

.btn-start-pressed {
  transform: scale(0.98);
  opacity: 0.9;
}

.btn-start-icon {
  width: 48rpx;
  height: 48rpx;
  position: relative;
  z-index: 2;
}

.btn-start-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  position: relative;
  z-index: 2;
}

.bottom-estimate {
  font-size: 24rpx;
  font-weight: 500;
  color: #3d4a3d;
  margin-top: 24rpx;
}

/* === Modal === */
.modal-mask {
  position: fixed; inset: 0; z-index: 100;
  background: rgba(0,0,0,0.4);
  display: flex; align-items: center; justify-content: center;
  padding: 80rpx;
  animation: fadeIn 0.2s ease;
}
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

.modal-card {
  width: 100%; background: #fff; border-radius: 48rpx;
  padding: 48rpx; display: flex; flex-direction: column; gap: 32rpx;
  animation: slideUp 0.3s ease;
}
@keyframes slideUp { from { transform: translateY(40rpx); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

.modal-title {
  font-size: 36rpx; font-weight: 700; color: #0b1c30; text-align: center;
}

.modal-input {
  width: 100%; height: 96rpx; padding: 0 40rpx;
  background: #eff4ff; border: 2rpx solid #d3e4fe;
  border-radius: 9999rpx; font-size: 30rpx; color: #0b1c30;
  box-sizing: border-box;
}
.modal-input:focus { border-color: var(--color-primary); }
.modal-placeholder { color: rgba(61,74,61,0.4); font-size: 28rpx; }

.picker-row {
  display: flex; gap: 24rpx;
}
.modal-picker {
  flex: 1; max-height: 480rpx; overflow-y: auto;
  border: 2rpx solid #e5eeff; border-radius: 32rpx;
  padding: 16rpx;
}
.picker-preview {
  width: 240rpx; height: 320rpx;
  border-radius: 32rpx; overflow: hidden;
  background: #f1f5f9; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
}
.preview-img { width: 100%; height: 100%; }
.preview-empty {
  font-size: 24rpx; color: #94a3b8; text-align: center; line-height: 1.6;
}
.picker-item {
  padding: 28rpx 32rpx; border-radius: 24rpx;
  font-size: 28rpx; font-weight: 500; color: #3d4a3d;
  border-bottom: 1rpx solid rgba(226,232,240,0.3);
}
.picker-item:last-child { border-bottom: none; }
.picker-item-hover { background: rgba(34,197,94,0.06); }
.picker-item-active {
  background: rgba(34,197,94,0.08); color: #006e2f; font-weight: 700;
}

.modal-buttons {
  display: flex; gap: 24rpx;
}
.modal-btn {
  flex: 1; height: 88rpx; border-radius: 9999rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; font-weight: 600;
}
.modal-btn-cancel { background: #f1f5f9; color: #64748b; }
.modal-btn-confirm { background: var(--color-primary); color: #fff; }

/* === Import Template Modal === */
.import-list { max-height: 480rpx; }
.import-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 28rpx 24rpx; border-radius: 24rpx;
  border-bottom: 1rpx solid rgba(226,232,240,0.4);
}
.import-item:last-child { border-bottom: none; }
.import-item-active { background: rgba(34,197,94,0.06); }
.import-item-left { display: flex; flex-direction: column; gap: 6rpx; }
.import-item-name { font-size: 28rpx; font-weight: 600; color: #0b1c30; }
.import-item-desc { font-size: 24rpx; color: #94a3b8; }
.import-radio {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  border: 3rpx solid #d3e4fe; display: flex; align-items: center;
  justify-content: center; flex-shrink: 0;
}
.import-radio-checked { border-color: var(--color-primary); }
.import-radio-dot {
  width: 24rpx; height: 24rpx; border-radius: 50%;
  background: var(--color-primary);
}
.import-empty {
  text-align: center; padding: 64rpx 0;
  font-size: 28rpx; color: #94a3b8;
}

/* === Tag Color Variants === */
.tag-strength  { color: #2563eb; background: #eff6ff; }
.tag-shape     { color: #9333ea; background: #faf5ff; }
.tag-hypertrophy { color: #dc2626; background: #fef2f2; }
.tag-compound  { color: #ea580c; background: #fff7ed; }
.tag-endurance { color: #16a34a; background: #f0fdf4; }
.tag-rehab     { color: #0891b2; background: #ecfeff; }

/* Update workout-tag to support color variants */
.workout-tag {
  font-size: 20rpx; font-weight: 700;
  padding: 4rpx 24rpx; border-radius: 9999rpx;
}

/* === Body Tab Emoji === */
.body-tab-emoji { font-size: 26rpx; line-height: 1; margin-right: 4rpx; }

/* === Import Template Card === */
.import-template-card {
  display: flex; align-items: center; justify-content: space-between;
  background: linear-gradient(135deg, #f0fdf4 0%, #fff 100%);
  border: 2rpx solid rgba(34,197,94,0.15);
  border-radius: 32rpx; padding: 36rpx 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(34,197,94,0.06);
}
.import-template-left {
  display: flex; align-items: center; gap: 24rpx;
}
.import-template-icon {
  font-size: 48rpx; line-height: 1;
}
.import-template-text {
  display: flex; flex-direction: column; gap: 6rpx;
}
.import-template-title {
  font-size: 30rpx; font-weight: 700; color: #0b1c30;
}
.import-template-desc {
  font-size: 24rpx; font-weight: 400; color: #94a3b8;
}
.import-template-arrow {
  width: 36rpx; height: 36rpx; opacity: 0.4; flex-shrink: 0;
}

/* ===== Picker Modal (居中弹窗 + 背景模糊) ===== */
.picker-mask {
  position: fixed; inset: 0; z-index: 200;
  background: rgba(0,0,0,0.3);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  display: flex; align-items: flex-end; justify-content: center;
}
.picker-card-modal {
  width: 100%; max-height: 92vh; background: #fff;
  border-radius: 48rpx 48rpx 0 0;
  padding: 40rpx 32rpx 48rpx;
  display: flex; flex-direction: column; gap: 20rpx;
  animation: pickerSlideUp 0.3s ease;
  box-shadow: 0 -16rpx 60rpx rgba(0,0,0,0.12);
}
@keyframes pickerSlideUp {
  from { transform: translateY(100%); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.picker-header {
  display: flex; flex-direction: column; gap: 4rpx;
  position: relative;
}
.picker-title {
  font-size: 38rpx; font-weight: 700; color: #0b1c30;
  line-height: 1.3; padding-left: 8rpx;
}
.picker-subtitle {
  font-size: 24rpx; font-weight: 400; color: #94a3b8;
  padding-left: 8rpx;
}
.picker-close {
  position: absolute; right: 0; top: 0;
  width: 44rpx; height: 44rpx; opacity: 0.45;
}

/* Search Bar */
.picker-search-bar {
  display: flex; align-items: center; gap: 16rpx;
  height: 80rpx; padding: 0 24rpx;
  background: #f1f5f9; border-radius: 48rpx;
  margin: 8rpx 0 4rpx;
}
.picker-search-icon { font-size: 32rpx; line-height: 1; opacity: 0.6; }
.picker-search-input {
  flex: 1; height: 80rpx; font-size: 28rpx; font-weight: 500;
  color: #0b1c30; background: transparent;
}
.picker-search-placeholder { color: #94a3b8; font-size: 26rpx; }
.picker-search-clear {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  background: rgba(0,0,0,0.08);
  display: flex; align-items: center; justify-content: center;
}
.picker-search-clear-text { font-size: 24rpx; color: #64748b; line-height: 1; }

/* Picker Tabs */
.picker-tabs-scroll {
  display: flex; white-space: nowrap;
  padding: 6rpx 0 2rpx;
}
.picker-tab-chip {
  display: inline-flex; flex-direction: row; align-items: center; gap: 6rpx;
  padding: 10rpx 20rpx; border-radius: 9999rpx;
  background: #f1f5f9;
  margin-right: 10rpx; flex-shrink: 0;
  transition: all 0.2s;
}
.picker-tab-emoji { font-size: 22rpx; line-height: 1; }
.picker-tab-name { font-size: 20rpx; font-weight: 500; color: #64748b; line-height: 1; }
.picker-tab-active {
  background: var(--color-primary);
  box-shadow: 0 4rpx 16rpx rgba(34,197,94,0.25);
}
.picker-tab-active .picker-tab-name { color: #fff; }

/* Picker List */
.picker-list-scroll { max-height: 900rpx; margin-top: 6rpx; flex: 1; }

.picker-ex-card {
  display: flex; flex-direction: row; align-items: center; gap: 24rpx;
  background: #f8f9ff;
  border-radius: 24rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.15s;
}
.picker-ex-card-hover {
  background: rgba(34,197,94,0.06);
  border-color: rgba(34,197,94,0.25);
  transform: scale(0.985);
}

/* 缩略图 */
.picker-ex-thumb {
  width: 120rpx; height: 120rpx; border-radius: 24rpx;
  flex-shrink: 0; overflow: hidden;
}
.picker-ex-thumb-placeholder {
  display: flex; align-items: center; justify-content: center;
  background: #e5eeff;
}
.picker-ex-thumb-emoji { font-size: 48rpx; line-height: 1; }

.picker-ex-body {
  display: flex; justify-content: space-between; align-items: center; gap: 12rpx;
  flex: 1; min-width: 0;
}
.picker-ex-left {
  display: flex; flex-direction: column; gap: 8rpx; flex: 1; min-width: 0;
}
.picker-ex-header-row {
  display: flex; align-items: center; gap: 12rpx;
}
.picker-ex-name {
  font-size: 28rpx; font-weight: 700; color: #0b1c30;
  line-height: 1.2;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  flex-shrink: 1;
}
.picker-ex-tag {
  font-size: 18rpx; font-weight: 700; padding: 2rpx 14rpx;
  border-radius: 9999rpx; line-height: 1.6; flex-shrink: 0;
}
.picker-ex-part {
  font-size: 20rpx; font-weight: 500; color: var(--color-primary);
  background: rgba(34,197,94,0.06); padding: 2rpx 12rpx;
  border-radius: 9999rpx; align-self: flex-start;
}
.picker-ex-params {
  display: flex; align-items: center; gap: 4rpx; flex-wrap: wrap;
}
.picker-ex-chip {
  font-size: 20rpx; font-weight: 500; color: #64748b;
  background: #fff; padding: 2rpx 12rpx; border-radius: 9999rpx;
  line-height: 1.5;
}
.picker-ex-divider {
  font-size: 18rpx; color: #cbd5e1; font-weight: 400; margin: 0 2rpx;
}
.picker-ex-add {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  background: var(--color-primary); flex-shrink: 0;
  color: #fff; font-size: 28rpx; font-weight: 600;
  display: flex; align-items: center; justify-content: center;
  line-height: 1;
  box-shadow: 0 4rpx 12rpx rgba(34,197,94,0.25);
}

/* 已添加状态 */
.picker-ex-card-added {
  opacity: 0.55; background: #f1f5f9;
}
.picker-ex-added {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  background: var(--color-primary); flex-shrink: 0;
  color: #fff; font-size: 24rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  line-height: 1;
}

.picker-ex-empty {
  padding: 80rpx 0; text-align: center;
}
.picker-ex-empty-text {
  font-size: 28rpx; color: #94a3b8;
}
