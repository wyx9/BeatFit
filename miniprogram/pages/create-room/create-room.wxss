/* ===== 创建训练房间 - 1:1 还原 _5/code.html ===== */

/* === Top AppBar === */
.header {
  position: fixed;
  top: 0;
  width: 100%;
  z-index: 50;
  background: transparent;
}

.header-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 40rpx;
  height: 128rpx;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.header-back {
  width: 48rpx;
  height: 48rpx;
}

.header-logo {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: -1rpx;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.header-notif {
  width: 48rpx;
  height: 48rpx;
  opacity: 0.7;
}

.header-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #d3e4fe;
}

.header-avatar-img {
  width: 100%;
  height: 100%;
}

/* === Main Content === */
.main {
  padding-top: 192rpx;
  padding-bottom: 256rpx;
  padding-left: 40rpx;
  padding-right: 40rpx;
  max-width: 960rpx;
  margin: 0 auto;
}

/* === Section === */
.section {
  margin-bottom: 64rpx;
}

.section-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #0b1c30;
  margin-bottom: 24rpx;
}

.section-desc {
  display: block;
  font-size: 28rpx;
  color: #3d4a3d;
  margin-top: 4rpx;
}

.section-header-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 32rpx;
}

.section-header-text {
  display: flex;
  flex-direction: column;
}

.section-header-text .section-title {
  margin-bottom: 0;
}

.section-action {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.action-icon {
  width: 36rpx;
  height: 36rpx;
}

.action-text {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--color-primary);
}

/* === Field Input === */
.field-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.field-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #3d4a3d;
  letter-spacing: 0.05em;
}

.field-input {
  width: 100%;
  height: 112rpx;
  padding: 0 48rpx;
  background: #fff;
  border: 2rpx solid rgba(188, 203, 185, 0.3);
  border-radius: 9999rpx;
  font-size: 36rpx;
  font-weight: 400;
  color: #0b1c30;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.02);
  box-sizing: border-box;
}

.field-input:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 8rpx rgba(34, 197, 94, 0.1);
}

.field-placeholder {
  color: rgba(61, 74, 61, 0.4);
  font-size: 32rpx;
}

/* === Body Part Tabs === */
.tabs-scroll {
  display: flex;
  white-space: nowrap;
  margin-bottom: 48rpx;
  padding-bottom: 16rpx;
  width: 100%;
}

.body-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 48rpx;
  border-radius: 9999rpx;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 1;
  background: #fff;
  border: 2rpx solid rgba(188, 203, 185, 0.3);
  color: #3d4a3d;
  margin-right: 16rpx;
  white-space: nowrap;
  flex-shrink: 0;
  height: 64rpx;
  box-sizing: border-box;
}

.body-tab-active {
  background: var(--color-primary);
  color: #fff;
  border-color: var(--color-primary);
  box-shadow: 0 4rpx 16rpx rgba(34, 197, 94, 0.2);
}

/* === Categories === */
.categories {
  display: flex;
  flex-direction: column;
  gap: 64rpx;
}

.category {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.category-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 2rpx solid rgba(188, 203, 185, 0.2);
  padding-bottom: 24rpx;
}

.category-title-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.category-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
  letter-spacing: 0.05em;
}

.category-title-empty {
  color: #3d4a3d;
}

.category-title-empty-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #3d4a3d;
  letter-spacing: 0.05em;
}

.category-icon {
  width: 40rpx;
  height: 40rpx;
}

.category-icon-empty {
  opacity: 0.5;
}

.category-action {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

/* === Workout Cards Grid === */
.workout-grid {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.workout-card {
  background: #fff;
  border: 2rpx solid rgba(188, 203, 185, 0.1);
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.workout-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.workout-name-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.workout-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #0b1c30;
}

.workout-tag {
  font-size: 20rpx;
  font-weight: 700;
  color: var(--color-primary);
  background: rgba(34, 197, 94, 0.1);
  padding: 4rpx 24rpx;
  border-radius: 9999rpx;
}

.workout-close {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.4;
}

.workout-inputs {
  display: flex;
  gap: 24rpx;
}

.workout-field {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.workout-label {
  font-size: 22rpx;
  font-weight: 500;
  color: #3d4a3d;
}

.workout-input {
  width: 100%;
  height: 80rpx;
  background: #e5eeff;
  border: none;
  border-radius: 24rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #0b1c30;
  padding: 0 8rpx;
  box-sizing: border-box;
}

.workout-input:focus {
  box-shadow: 0 0 0 4rpx rgba(34, 197, 94, 0.3);
}

/* === Empty State === */
.empty-state {
  border: 4rpx dashed rgba(188, 203, 185, 0.3);
  border-radius: 32rpx;
  padding: 64rpx;
  text-align: center;
  background: rgba(239, 244, 255, 0.3);
}

.empty-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #3d4a3d;
}

/* === Room Settings === */
.settings-card {
  background: #eff4ff;
  border-radius: 48rpx;
  padding: 48rpx;
  margin-bottom: 64rpx;
}

.settings-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #0b1c30;
  letter-spacing: 0.05em;
  margin-bottom: 32rpx;
}

.settings-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.chip {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #fff;
  border: 2rpx solid rgba(188, 203, 185, 0.2);
  border-radius: 9999rpx;
  padding: 16rpx 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.02);
}

.chip-icon {
  width: 36rpx;
  height: 36rpx;
}

.chip-text {
  font-size: 24rpx;
  font-weight: 500;
  color: #3d4a3d;
}

/* === Bottom Action Bar === */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  z-index: 50;
  background: rgba(248, 249, 255, 0.9);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-top: 2rpx solid rgba(188, 203, 185, 0.1);
  padding: 48rpx 40rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.bottom-bar-inner {
  max-width: 960rpx;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.btn-start {
  width: 100%;
  height: 112rpx;
  background: var(--color-primary);
  border-radius: 9999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow: 0 16rpx 48rpx rgba(34, 197, 94, 0.3);
  transition: all 0.2s;
  position: relative;
  overflow: hidden;
}

.btn-start-pressed {
  transform: scale(0.98);
  opacity: 0.9;
}

.btn-start-icon {
  width: 48rpx;
  height: 48rpx;
  position: relative;
  z-index: 2;
}

.btn-start-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  position: relative;
  z-index: 2;
}

.bottom-estimate {
  font-size: 24rpx;
  font-weight: 500;
  color: #3d4a3d;
  margin-top: 24rpx;
}

/* === Modal === */
.modal-mask {
  position: fixed; inset: 0; z-index: 100;
  background: rgba(0,0,0,0.4);
  display: flex; align-items: center; justify-content: center;
  padding: 80rpx;
  animation: fadeIn 0.2s ease;
}
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

.modal-card {
  width: 100%; background: #fff; border-radius: 48rpx;
  padding: 48rpx; display: flex; flex-direction: column; gap: 32rpx;
  animation: slideUp 0.3s ease;
}
@keyframes slideUp { from { transform: translateY(40rpx); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

.modal-title {
  font-size: 36rpx; font-weight: 700; color: #0b1c30; text-align: center;
}

.modal-input {
  width: 100%; height: 96rpx; padding: 0 40rpx;
  background: #eff4ff; border: 2rpx solid #d3e4fe;
  border-radius: 9999rpx; font-size: 30rpx; color: #0b1c30;
  box-sizing: border-box;
}
.modal-input:focus { border-color: var(--color-primary); }
.modal-placeholder { color: rgba(61,74,61,0.4); font-size: 28rpx; }

.picker-row {
  display: flex; gap: 24rpx;
}
.modal-picker {
  flex: 1; max-height: 480rpx; overflow-y: auto;
  border: 2rpx solid #e5eeff; border-radius: 32rpx;
  padding: 16rpx;
}
.picker-preview {
  width: 240rpx; height: 320rpx;
  border-radius: 32rpx; overflow: hidden;
  background: #f1f5f9; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
}
.preview-img { width: 100%; height: 100%; }
.preview-empty {
  font-size: 24rpx; color: #94a3b8; text-align: center; line-height: 1.6;
}
.picker-item {
  padding: 28rpx 32rpx; border-radius: 24rpx;
  font-size: 28rpx; font-weight: 500; color: #3d4a3d;
  border-bottom: 1rpx solid rgba(226,232,240,0.3);
}
.picker-item:last-child { border-bottom: none; }
.picker-item-hover { background: rgba(34,197,94,0.06); }
.picker-item-active {
  background: rgba(34,197,94,0.08); color: #006e2f; font-weight: 700;
}

.modal-buttons {
  display: flex; gap: 24rpx;
}
.modal-btn {
  flex: 1; height: 88rpx; border-radius: 9999rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; font-weight: 600;
}
.modal-btn-cancel { background: #f1f5f9; color: #64748b; }
.modal-btn-confirm { background: var(--color-primary); color: #fff; }
