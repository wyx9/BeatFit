<!-- 创建训练房间 -->
<view class="page">
  <!-- TopAppBar -->
  <view class="header" style="padding-top: {{statusBarHeight}}px;">
    <view class="header-inner">
      <view class="header-left">
        <image class="header-back" src="/images/icon-arrow-back.svg" mode="aspectFit" bindtap="goBack" />
        <text class="header-logo">律动健身</text>
      </view>
    </view>
  </view>

  <view class="main">
    <!-- 房间名称 -->
    <view class="section">
      <text class="section-title">创建训练空间</text>
      <input class="field-input" placeholder="例如：晨间活力力量训练" placeholder-class="field-placeholder" value="{{roomName}}" bindinput="onRoomNameInput" />
    </view>

    <!-- 动作配置 -->
    <view class="section">
      <view class="section-header-row">
        <view>
          <text class="section-title">配置动作</text>
          <text class="section-desc">按部位管理您的训练计划</text>
        </view>
        <view class="section-action" bindtap="showAddCategory">
          <image class="action-icon" src="/images/icon-add.svg" mode="aspectFit" />
          <text class="action-text">添加分类</text>
        </view>
      </view>

      <!-- 部位 Tab -->
      <scroll-view class="tabs-scroll" scroll-x enable-flex>
        <view class="body-tab {{activePart === item.key ? 'body-tab-active' : ''}}" wx:for="{{categories}}" wx:key="key" bindtap="switchPart" data-part="{{item.key}}">{{item.name}}</view>
      </scroll-view>

      <!-- 分类列表 -->
      <view class="categories">
        <block wx:for="{{filteredCategories}}" wx:key="key">
          <view class="category">
            <view class="category-header">
              <view class="category-title-wrap">
                <text class="category-title">{{item.name}}</text>
              </view>
              <view class="category-action" bindtap="showAddExercise" data-cat="{{item.key}}">
                <image class="action-icon" src="/images/icon-add.svg" mode="aspectFit" />
                <text class="action-text">添加动作</text>
              </view>
            </view>

            <!-- 动作卡片列表 -->
            <view class="workout-grid" wx:if="{{item.exercises.length > 0}}">
              <view class="workout-card" wx:for="{{item.exercises}}" wx:for-item="ex" wx:key="name">
                <view class="workout-card-header">
                  <view class="workout-name-wrap">
                    <text class="workout-name">{{ex.name}}</text>
                    <text class="workout-tag">{{ex.tag}}</text>
                  </view>
                  <image class="workout-close" src="/images/icon-close.svg" mode="aspectFit" bindtap="removeExercise" data-cat="{{item.key}}" data-name="{{ex.name}}" />
                </view>
                <view class="workout-inputs">
                  <view class="workout-field"><text class="workout-label">组数</text><input class="workout-input" type="number" value="{{ex.sets}}" /></view>
                  <view class="workout-field"><text class="workout-label">次数</text><input class="workout-input" type="number" value="{{ex.reps}}" /></view>
                  <view class="workout-field"><text class="workout-label">动作时长(秒)</text><input class="workout-input" type="number" value="{{ex.duration_sec}}" /></view>
                  <view class="workout-field"><text class="workout-label">组间休息(秒)</text><input class="workout-input" type="number" value="{{ex.rest_sec}}" /></view>
                </view>
              </view>
            </view>

            <!-- 空状态 -->
            <view class="empty-state" wx:else>
              <text class="empty-text">暂无动作，点击"添加动作"按钮添加</text>
            </view>
          </view>
        </block>
      </view>
    </view>

    <!-- 房间设置 -->
    <view class="settings-card">
      <text class="settings-title">房间设置</text>
      <view class="settings-chips">
        <view class="chip"><image class="chip-icon" src="/images/icon-lock-open.svg" mode="aspectFit" /><text class="chip-text">公开房间</text></view>
        <view class="chip"><image class="chip-icon" src="/images/icon-music.svg" mode="aspectFit" /><text class="chip-text">开启背景音乐</text></view>
        <view class="chip"><image class="chip-icon" src="/images/icon-groups.svg" mode="aspectFit" /><text class="chip-text">最多 5 人</text></view>
      </view>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-bar">
    <view class="bottom-bar-inner">
      <view class="btn-start" hover-class="btn-start-pressed" bindtap="handleCreate">
        <image class="btn-start-icon" src="/images/icon-play-arrow.svg" mode="aspectFit" />
        <text class="btn-start-text">立即创建房间</text>
        <view class="btn-shimmer"></view>
      </view>
      <text class="bottom-estimate">预计总时长: {{totalDuration}} 分钟</text>
    </view>
  </view>

  <!-- 添加分类弹窗 -->
  <view class="modal-mask" wx:if="{{showCategoryModal}}" bindtap="hideModals">
    <view class="modal-card" catchtap="noop">
      <text class="modal-title">添加分类</text>
      <input class="modal-input" placeholder="分类名称，如：核心训练" placeholder-class="modal-placeholder" value="{{newCategoryName}}" bindinput="onCatNameInput" />
      <view class="modal-buttons">
        <view class="modal-btn modal-btn-cancel" bindtap="hideModals"><text>取消</text></view>
        <view class="modal-btn modal-btn-confirm" bindtap="confirmAddCategory"><text>确认添加</text></view>
      </view>
    </view>
  </view>

  <!-- 添加动作弹窗 -->
  <view class="modal-mask" wx:if="{{showExerciseModal}}" bindtap="hideModals">
    <view class="modal-card" catchtap="noop">
      <text class="modal-title">添加动作到「{{addingToCategory}}」</text>
      <view class="picker-row">
        <view class="modal-picker">
          <view class="picker-item {{addingExercise === item.name ? 'picker-item-active' : ''}}" hover-class="picker-item-hover" wx:for="{{availableExercises}}" wx:key="name" bindtap="selectExercise" data-name="{{item.name}}">{{item.name}}</view>
        </view>
        <view class="picker-preview">
          <image wx:if="{{previewImage}}" class="preview-img" src="{{previewImage}}" mode="aspectFill" />
          <view wx:else class="preview-empty"><text>选择动作\n查看预览</text></view>
        </view>
      </view>
      <view class="modal-buttons">
        <view class="modal-btn modal-btn-cancel" bindtap="hideModals"><text>取消</text></view>
        <view class="modal-btn modal-btn-confirm" bindtap="confirmAddExercise"><text>确认添加</text></view>
      </view>
    </view>
  </view>
</view>
