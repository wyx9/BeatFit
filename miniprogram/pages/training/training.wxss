/* ===== 训练中页面 ===== */

/* === Header === */
.header {
  position: fixed; top: 0; width: 100%; z-index: 50;
  background: transparent;
}
.header-inner {
  display: flex; justify-content: space-between; align-items: center;
  height: 88rpx; padding: 0 40rpx;
}
.header-left { display: flex; align-items: center; gap: 24rpx; }
.header-avatar {
  width: 64rpx; height: 64rpx; border-radius: 50%; overflow: hidden;
  box-shadow: 0 0 0 4rpx rgba(34,197,94,0.1);
}
.header-avatar-img { width: 100%; height: 100%; }
.header-avatar-placeholder {
  width: 100%; height: 100%;
  background: linear-gradient(135deg, #22c55e, #16a34a);
  display: flex; align-items: center; justify-content: center;
}
.avatar-initial { font-size: 24rpx; font-weight: 700; color: #fff; }
.header-title { font-size: 40rpx; font-weight: 800; color: #006e2f; letter-spacing: -1rpx; }
.header-settings { width: 44rpx; height: 44rpx; opacity: 0.6; }

/* === Main === */
.main {
  padding-top: 168rpx; padding-bottom: 256rpx;
  padding-left: 40rpx; padding-right: 40rpx;
  max-width: 900rpx; margin: 0 auto;
}

/* === Timer === */
.timer-section {
  display: flex; flex-direction: column; align-items: center;
  margin-bottom: 40rpx;
}
.timer-ring-wrap {
  position: relative;
  width: 510rpx; height: 510rpx;
}
/* 圆环：conic-gradient 实现原生环状进度 */
.timer-ring {
  position: absolute; inset: 0; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
}
/* 中间挖空 → 形成圆环效果 */
.timer-ring-hole {
  position: absolute;
  top: 4.5%; left: 4.5%; right: 4.5%; bottom: 4.5%;
  border-radius: 50%;
  background: #f8f9ff;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
}
.timer-time {
  display: block;
  font-size: 128rpx; font-weight: 800; color: #0b1c30;
  letter-spacing: -4rpx; line-height: 1;
  position: relative; z-index: 2;
}
.timer-phase {
  display: block;
  font-size: 26rpx; font-weight: 600; color: #565e74;
  margin-top: 4rpx;
  position: relative; z-index: 2;
}
/* 中心文字 */
.timer-center {
  z-index: 10; text-align: center;
}
.timer-time {
  display: block;
  font-size: 128rpx; font-weight: 800; color: #0b1c30;
  letter-spacing: -4rpx; line-height: 1;
}
.timer-phase {
  display: block;
  font-size: 26rpx; font-weight: 600; color: #565e74;
  margin-top: 4rpx;
}

/* === 总时间进度条 === */
.total-time-bar {
  background: #fff; border-radius: 9999rpx;
  padding: 28rpx 40rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  border: 1rpx solid #e5eeff;
  display: flex; flex-direction: column; gap: 16rpx;
  margin-bottom: 48rpx;
}
.total-time-row {
  display: flex; justify-content: space-between; align-items: center;
}
.total-time-label {
  font-size: 28rpx; font-weight: 600; color: #3d4a3d;
}
.total-time-value {
  font-size: 28rpx; font-weight: 700; color: var(--color-primary);
}
.total-progress-track {
  width: 100%; height: 4rpx; background: #eff4ff;
  border-radius: 9999rpx; overflow: hidden;
}
.total-progress-fill {
  height: 100%; background: #22c55e; border-radius: 9999rpx;
  transition: width 0.5s ease;
}
.timer-text {
  text-align: center; z-index: 10;
}
.timer-time {
  display: block;
  font-size: 128rpx; font-weight: 800; color: #0b1c30;
  letter-spacing: -4rpx; line-height: 1;
}
.timer-label {
  display: block;
  font-size: 28rpx; font-weight: 600; color: #565e74;
  letter-spacing: 4rpx; margin-top: 8rpx;
}

/* === Current Exercise Card === */
.exercise-card {
  background: #fff;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.04);
  border-radius: 64rpx; border: 2rpx solid #eff4ff;
  padding: 48rpx; display: flex; flex-direction: column; gap: 32rpx;
  margin-bottom: 48rpx;
}
.card-header {
  display: flex; justify-content: space-between; align-items: flex-start;
}
.card-header-left { display: flex; flex-direction: column; gap: 8rpx; }
.card-badge {
  background: rgba(34,197,94,0.1); color: #006e2f;
  font-size: 24rpx; font-weight: 600;
  padding: 4rpx 24rpx; border-radius: 9999rpx;
  display: inline-block; width: fit-content;
}
.card-exercise-name {
  font-size: 40rpx; font-weight: 700; color: #0b1c30;
}
.card-set-info {
  font-size: 28rpx; color: #565e74;
}
.card-thumb {
  width: 128rpx; height: 128rpx; border-radius: 32rpx;
  background: #e5eeff; overflow: hidden;
}
.card-thumb-img { width: 100%; height: 100%; opacity: 0.5; }

.card-stats {
  display: flex; gap: 32rpx;
}
.stat-item {
  flex: 1; display: flex; align-items: center; gap: 24rpx;
  background: #eff4ff; border-radius: 32rpx; padding: 24rpx;
}
.stat-item-active {
  background: rgba(34,197,94,0.08); border: 2rpx solid rgba(34,197,94,0.2);
}
.stat-icon-wrap {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  background: #fff; display: flex; align-items: center; justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.stat-icon-wrap-active {
  background: #fff; min-width: 96rpx;
}
.stat-icon { width: 40rpx; height: 40rpx; }
.stat-icon-text { font-size: 28rpx; font-weight: 700; color: #006e2f; }
.stat-text { display: flex; flex-direction: column; }
.stat-label { font-size: 22rpx; color: #565e74; font-weight: 500; }
.stat-value { font-size: 40rpx; font-weight: 700; color: #0b1c30; line-height: 1.1; }
.stat-value-active { color: #006e2f; }

/* === Next Exercise === */
.next-section { margin-bottom: 64rpx; }
.next-label {
  font-size: 28rpx; font-weight: 600; color: #565e74;
  margin-bottom: 24rpx; padding-left: 8rpx;
}
.next-card {
  background: rgba(255,255,255,0.4); border: 2rpx solid #e5eeff;
  border-radius: 32rpx; padding: 32rpx;
  display: flex; align-items: center; justify-content: space-between;
}
.next-card-left { display: flex; align-items: center; gap: 32rpx; }
.next-thumb {
  width: 96rpx; height: 96rpx; border-radius: 24rpx;
  background: #dce9ff; overflow: hidden; opacity: 0.8;
}
.next-thumb-img { width: 100%; height: 100%; }
.next-info { display: flex; flex-direction: column; gap: 4rpx; }
.next-name { font-size: 32rpx; font-weight: 700; color: #3d4a3d; }
.next-duration { font-size: 24rpx; color: #565e74; }
.next-arrow { width: 32rpx; height: 32rpx; opacity: 0.3; }

/* === Controls === */
.controls {
  display: flex; gap: 32rpx; margin-top: 64rpx;
}
.btn-pause {
  flex: 1; height: 112rpx; background: #e5eeff;
  border-radius: 9999rpx; display: flex; align-items: center;
  justify-content: center; gap: 16rpx;
  font-size: 32rpx; font-weight: 700; color: #0b1c30;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  transition: all 0.2s;
}
.btn-pause-pressed { transform: scale(0.95); background: #dce9ff; }
.btn-pause-icon { width: 40rpx; height: 40rpx; }
.btn-pause-text { font-size: 32rpx; font-weight: 700; color: #0b1c30; }

.btn-stop {
  flex: 1; height: 112rpx; background: #22c55e;
  border-radius: 9999rpx; display: flex; align-items: center;
  justify-content: center; gap: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  transition: all 0.2s; position: relative; overflow: hidden;
}
.btn-stop-pressed { transform: scale(0.95); }
.btn-stop-icon { width: 40rpx; height: 40rpx; position: relative; z-index: 2; }
.btn-stop-text {
  font-size: 32rpx; font-weight: 700; color: #fff;
  position: relative; z-index: 2;
}

/* === Bottom Nav === */
.bottom-nav {
  position: fixed; bottom: 0; left: 0; width: 100%; z-index: 50;
  display: flex; justify-content: space-around; align-items: center;
  padding: 32rpx 32rpx calc(64rpx + env(safe-area-inset-bottom));
  background: rgba(248,249,255,0.95);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  box-shadow: 0 -8rpx 40rpx rgba(0,0,0,0.04);
}
.nav-item {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; padding: 12rpx 40rpx;
  color: #565e74; transition: all 0.2s;
}
.nav-active { color: #006e2f; background: rgba(34,197,94,0.06); border-radius: 32rpx; }
.nav-icon { width: 48rpx; height: 48rpx; }
.nav-label { font-size: 22rpx; font-weight: 500; margin-top: 2rpx; color: #565e74; }
.nav-label-active { color: #006e2f; font-weight: 700; }
