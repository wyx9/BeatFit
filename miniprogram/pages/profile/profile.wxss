/* ===== 个人中心 ===== */

/* === Header === */
.header {
  position: fixed;
  top: 0;
  width: 100%;
  z-index: 50;
  background: transparent;
}

.header-inner {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 88rpx;
  padding: 0 40rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #131313;
}

/* === Main === */
.main {
  padding-top: 168rpx;
  padding-bottom: 256rpx;
  padding-left: 40rpx;
  padding-right: 40rpx;
}

/* === User Card === */
.user-card {
  display: flex;
  align-items: center;
  gap: 32rpx;
  background: linear-gradient(135deg, rgba(34,197,94,0.08), rgba(34,197,94,0.02));
  border: 2rpx solid rgba(34,197,94,0.1);
  border-radius: 48rpx;
  padding: 48rpx;
  margin-bottom: 40rpx;
}

.user-avatar-wrap {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 6rpx solid rgba(34,197,94,0.2);
  flex-shrink: 0;
}

.user-avatar {
  width: 100%;
  height: 100%;
}

.user-avatar-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #22c55e, #16a34a);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-avatar-initial {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
}

.user-text {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.user-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #131313;
}

.user-badge {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.user-level {
  background: var(--color-primary);
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  padding: 4rpx 20rpx;
  border-radius: 9999rpx;
}

.user-title {
  font-size: 24rpx;
  color: #454747;
  font-weight: 500;
}

/* === Stats Row === */
.stats-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 48rpx;
}

.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #fff;
  border: 2rpx solid rgba(226,232,240,0.4);
  border-radius: 40rpx;
  padding: 32rpx 16rpx;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.stat-unit {
  font-size: 20rpx;
  color: #454747;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #94a3b8;
  font-weight: 500;
}

/* === Menu Section === */
.menu-section {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  background: #fff;
  border: 2rpx solid rgba(226,232,240,0.3);
  border-radius: 40rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 36rpx 40rpx;
  border-bottom: 1rpx solid rgba(226,232,240,0.2);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item-pressed {
  background: rgba(34,197,94,0.04);
}

.menu-icon {
  width: 44rpx;
  height: 44rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: #131313;
}

.menu-arrow {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.3;
}

/* === Logout === */
.logout-section {
  margin-top: 48rpx;
  padding: 0 24rpx;
}

.btn-logout {
  width: 100%;
  height: 96rpx;
  background: #fff;
  border: 2rpx solid rgba(239, 68, 68, 0.3);
  border-radius: 9999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.btn-logout-pressed {
  transform: scale(0.98);
  background: rgba(239, 68, 68, 0.05);
}

.btn-logout-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ef4444;
}

/* === Bottom Nav === */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  z-index: 50;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 32rpx 32rpx calc(64rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-top: 1rpx solid rgba(226, 232, 240, 0.3);
  box-shadow: 0 -16rpx 60rpx rgba(0, 0, 0, 0.02);
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 48rpx;
  color: #454747;
  transition: all 0.2s;
}

.nav-active {
  color: var(--color-primary);
}

.nav-icon {
  width: 48rpx;
  height: 48rpx;
}

.nav-label {
  font-size: 22rpx;
  font-weight: 700;
  margin-top: 2rpx;
  color: #454747;
}

.nav-label-active {
  color: var(--color-primary);
}
