/* ===== 个人中心 ===== */

/* Page fade-in for smooth tab transitions */
.page {
  animation: pageFadeIn 0.2s ease both;
}
@keyframes pageFadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

/* === Header === */
.header {
  position: fixed;
  top: 0;
  width: 100%;
  z-index: 50;
  background: transparent;
}

.header-inner {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 88rpx;
  padding: 0 40rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #131313;
}

/* === Main === */
.main {
  padding-top: 168rpx;
  padding-bottom: 256rpx;
  padding-left: 40rpx;
  padding-right: 40rpx;
}

/* === User Card === */
.user-card {
  display: flex;
  align-items: center;
  gap: 32rpx;
  background: linear-gradient(135deg, rgba(34,197,94,0.08), rgba(34,197,94,0.02));
  border: 2rpx solid rgba(34,197,94,0.1);
  border-radius: 48rpx;
  padding: 48rpx;
  margin-bottom: 40rpx;
}

.user-avatar-wrap {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 6rpx solid rgba(34,197,94,0.2);
  flex-shrink: 0;
}

.user-avatar {
  width: 100%;
  height: 100%;
}

.user-avatar-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #22c55e, #16a34a);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-avatar-initial {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
}

.user-text {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.user-name-row {
  display: flex; align-items: center; gap: 16rpx;
}
.user-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #131313;
}
.user-name-edit {
  font-size: 32rpx; color: #94a3b8;
  transition: color 0.15s;
}
.user-name-row:active .user-name-edit {
  color: var(--color-primary);
}

.user-badge {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.user-level {
  background: var(--color-primary);
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  padding: 4rpx 20rpx;
  border-radius: 9999rpx;
}

.user-title {
  font-size: 24rpx;
  color: #454747;
  font-weight: 500;
}

/* === Stats Row === */
.stats-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 48rpx;
}

.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #fff;
  border: 2rpx solid rgba(226,232,240,0.4);
  border-radius: 40rpx;
  padding: 32rpx 16rpx;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.stat-unit {
  font-size: 20rpx;
  color: #454747;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #94a3b8;
  font-weight: 500;
}

/* === Menu Section === */
.menu-section {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  background: #fff;
  border: 2rpx solid rgba(226,232,240,0.3);
  border-radius: 40rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 36rpx 40rpx;
  border-bottom: 1rpx solid rgba(226,232,240,0.2);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item-pressed {
  background: rgba(34,197,94,0.04);
}

.menu-icon {
  width: 44rpx;
  height: 44rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: #131313;
}

.menu-arrow {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.3;
}

/* === Logout === */
.logout-section {
  margin-top: 48rpx;
  padding: 0 24rpx;
}

.btn-logout {
  width: 100%;
  height: 96rpx;
  background: #fff;
  border: 2rpx solid rgba(239, 68, 68, 0.3);
  border-radius: 9999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.btn-logout-pressed {
  transform: scale(0.98);
  background: rgba(239, 68, 68, 0.05);
}

.btn-logout-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ef4444;
}

/* === Bottom Nav === */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  z-index: 50;
  display: flex;
  justify-content: space-around;
  align-items: center;
  gap: 0;
  padding: 24rpx 40rpx calc(56rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-top: 1rpx solid rgba(226, 232, 240, 0.3);
  box-shadow: 0 -16rpx 60rpx rgba(0, 0, 0, 0.02);
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  color: #454747;
  transition: all 0.2s;
}

.nav-active {
  color: var(--color-primary);
}

.nav-icon {
  width: 48rpx;
  height: 48rpx;
}

.nav-label {
  font-size: 22rpx;
  font-weight: 700;
  margin-top: 2rpx;
  color: #454747;
}

.nav-label-active {
  color: var(--color-primary);
}

/* === Nickname Edit Modal === */
.nickname-overlay {
  position: fixed; top: 0; left: 0; width: 100%; height: 100%;
  z-index: 200;
  background: rgba(0,0,0,0.45);
  display: flex; align-items: center; justify-content: center;
  animation: overlayFadeIn 0.2s ease both;
}
@keyframes overlayFadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}
.nickname-modal {
  width: 600rpx;
  background: #fff;
  border-radius: 40rpx;
  padding: 48rpx 40rpx 36rpx;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.12);
  animation: modalSlideUp 0.25s ease both;
}
@keyframes modalSlideUp {
  from { transform: translateY(40rpx); opacity: 0; }
  to   { transform: translateY(0); opacity: 1; }
}
.nickname-modal-title {
  display: block; text-align: center;
  font-size: 34rpx; font-weight: 700; color: #0b1c30;
  margin-bottom: 36rpx;
}
.nickname-input {
  width: 100%; height: 96rpx;
  background: #f1f5f9;
  border-radius: 24rpx;
  padding: 0 28rpx; box-sizing: border-box;
  font-size: 32rpx; font-weight: 600; color: #0b1c30;
  text-align: center;
}
.nickname-modal-btns {
  display: flex; gap: 24rpx;
  margin-top: 36rpx;
}
.nickname-btn {
  flex: 1; height: 88rpx;
  display: flex; align-items: center; justify-content: center;
  border-radius: 9999rpx;
  transition: all 0.15s;
}
.nickname-btn-cancel {
  background: #f1f5f9;
}
.nickname-btn-confirm {
  background: var(--color-primary);
}
.nickname-btn-pressed {
  transform: scale(0.97); opacity: 0.85;
}
.nickname-btn .nickname-btn-text {
  font-size: 30rpx; font-weight: 600;
}
.nickname-btn-cancel .nickname-btn-text {
  color: #64748b;
}
.nickname-btn-confirm .nickname-btn-text {
  color: #fff;
}
