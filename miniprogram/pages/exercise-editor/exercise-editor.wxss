/* ===== 模板编辑页 ===== */

/* === Header === */
.header {
  position: fixed; top: 0; width: 100%; z-index: 50;
  background: rgba(248,249,255,0.95);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
}
.header-inner {
  display: flex; justify-content: space-between; align-items: center;
  height: 88rpx; padding: 0 40rpx;
}
.header-left {
  display: flex; align-items: center; gap: 24rpx;
}
.header-back { width: 48rpx; height: 48rpx; }
.header-title { font-size: 36rpx; font-weight: 700; color: #0b1c30; }
.header-save {
  background: var(--color-primary); padding: 16rpx 40rpx; border-radius: 9999rpx;
}
.save-text { font-size: 28rpx; font-weight: 600; color: #fff; }

/* === Main === */
.main {
  padding-top: 148rpx; padding-bottom: 200rpx;
  padding-left: 40rpx; padding-right: 40rpx;
  max-width: 900rpx; margin: 0 auto;
}

/* === Section === */
.section { margin-bottom: 48rpx; }
.section-label {
  display: block; font-size: 28rpx; font-weight: 600; color: #3d4a3d;
  margin-bottom: 20rpx;
}
.section-header-row {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 20rpx;
}
.section-header-row .section-label { margin-bottom: 0; }

/* === Name Input === */
.name-input {
  width: 100%; height: 96rpx; padding: 0 40rpx;
  background: #fff; border: 2rpx solid #e5eeff;
  border-radius: 48rpx; font-size: 32rpx; font-weight: 500; color: #0b1c30;
  box-sizing: border-box;
}
.name-input:focus { border-color: var(--color-primary); }
.name-placeholder { color: rgba(61,74,61,0.4); font-size: 28rpx; }

/* === Exercise Cards === */
.exercise-list { display: flex; flex-direction: column; gap: 24rpx; margin-bottom: 32rpx; }
.exercise-card {
  background: #fff; border: 2rpx solid rgba(188,203,185,0.1);
  border-radius: 32rpx; padding: 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}
.card-header {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 24rpx;
}
.card-title-row { display: flex; align-items: center; gap: 16rpx; }
.card-name { font-size: 30rpx; font-weight: 700; color: #0b1c30; }
.card-tag {
  font-size: 20rpx; font-weight: 700; color: var(--color-primary);
  background: rgba(34,197,94,0.1); padding: 4rpx 20rpx; border-radius: 9999rpx;
}
.card-remove { width: 32rpx; height: 32rpx; opacity: 0.4; }

.card-inputs { display: flex; gap: 20rpx; }
.card-field { flex: 1; display: flex; flex-direction: column; gap: 6rpx; }
.field-label { font-size: 22rpx; font-weight: 500; color: #3d4a3d; }
.field-input {
  width: 100%; height: 72rpx; background: #e5eeff;
  border: none; border-radius: 20rpx; text-align: center;
  font-size: 26rpx; font-weight: 700; color: #0b1c30;
  padding: 0 6rpx; box-sizing: border-box;
}
.field-input:focus { box-shadow: 0 0 0 4rpx rgba(34,197,94,0.3); }
.field-value {
  display: flex; align-items: center; justify-content: center;
  height: 72rpx; font-size: 26rpx; font-weight: 700; color: #0b1c30;
}

/* === Empty State === */
.empty-state {
  border: 4rpx dashed rgba(188,203,185,0.3); border-radius: 32rpx;
  padding: 64rpx; text-align: center; margin-bottom: 32rpx;
}
.empty-text { font-size: 28rpx; font-weight: 500; color: #3d4a3d; }

/* === Add Button === */
.add-btn {
  display: flex; align-items: center; justify-content: center; gap: 12rpx;
  height: 96rpx; background: #e5eeff; border: 2rpx dashed rgba(34,197,94,0.3);
  border-radius: 48rpx;
}
.add-icon { width: 40rpx; height: 40rpx; }
.add-text { font-size: 28rpx; font-weight: 600; color: var(--color-primary); }

/* === Bottom Bar (readonly) === */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; width: 100%; z-index: 50;
  background: rgba(248,249,255,0.95);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  padding: 40rpx 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}
.bottom-bar-inner { max-width: 900rpx; margin: 0 auto; }
.btn-save-as {
  width: 100%; height: 104rpx; background: var(--color-primary);
  border-radius: 9999rpx; display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(34,197,94,0.3);
}
.btn-save-as-pressed { transform: scale(0.98); opacity: 0.9; }
.btn-save-as-text { font-size: 36rpx; font-weight: 700; color: #fff; }

/* === Modal Mask === */
.modal-mask {
  position: fixed; inset: 0; z-index: 200;
  background: rgba(0,0,0,0.45);
  display: flex; align-items: flex-end; justify-content: center;
}
.modal-card {
  width: 100%; max-height: 82vh; background: #fff;
  border-radius: 48rpx 48rpx 0 0;
  padding: 24rpx 32rpx 64rpx;
  display: flex; flex-direction: column; gap: 20rpx;
  animation: slideUp 0.3s ease;
}
@keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }

/* 拖拽指示条 */
.modal-drag-bar {
  width: 72rpx; height: 8rpx; background: #d3e4fe;
  border-radius: 4rpx; margin: 0 auto 16rpx;
}

.modal-header {
  display: flex; flex-direction: column; gap: 4rpx;
  position: relative;
}
.modal-title {
  font-size: 38rpx; font-weight: 700; color: #0b1c30;
  line-height: 1.3; padding-left: 8rpx;
}
.modal-subtitle {
  font-size: 24rpx; font-weight: 400; color: #94a3b8;
  padding-left: 8rpx;
}
.modal-close {
  position: absolute; right: 0; top: 0;
  width: 44rpx; height: 44rpx; opacity: 0.45;
}

/* === Search Bar === */
.search-bar {
  display: flex; align-items: center; gap: 16rpx;
  height: 80rpx; padding: 0 24rpx;
  background: #f1f5f9; border-radius: 48rpx;
  margin: 8rpx 0 4rpx;
}
.search-icon-emoji { font-size: 32rpx; line-height: 1; opacity: 0.6; }
.search-input {
  flex: 1; height: 80rpx; font-size: 28rpx; font-weight: 500;
  color: #0b1c30; background: transparent;
}
.search-placeholder { color: #94a3b8; font-size: 26rpx; }
.search-clear {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  background: rgba(0,0,0,0.08);
  display: flex; align-items: center; justify-content: center;
}
.search-clear-text { font-size: 24rpx; color: #64748b; line-height: 1; }

/* === Picker Tabs === */
.picker-tabs {
  display: flex; white-space: nowrap;
  padding: 6rpx 0 2rpx;
}
.picker-tab {
  display: inline-flex; flex-direction: row; align-items: center; gap: 8rpx;
  padding: 14rpx 28rpx; border-radius: 9999rpx;
  background: #f1f5f9;
  margin-right: 14rpx; flex-shrink: 0;
  transition: all 0.2s;
}
.picker-tab-emoji { font-size: 26rpx; line-height: 1; }
.picker-tab-name { font-size: 24rpx; font-weight: 500; color: #64748b; line-height: 1; }
.picker-tab-active {
  background: var(--color-primary);
  box-shadow: 0 4rpx 16rpx rgba(34,197,94,0.25);
}
.picker-tab-active .picker-tab-name { color: #fff; }

/* === Picker List === */
.picker-list { max-height: 520rpx; margin-top: 6rpx; }

.picker-card {
  background: #f8f9ff;
  border-radius: 24rpx;
  padding: 24rpx 24rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.15s;
}
.picker-card-hover {
  background: rgba(34,197,94,0.06);
  border-color: rgba(34,197,94,0.25);
  transform: scale(0.985);
}

.picker-card-body {
  display: flex; justify-content: space-between; align-items: center; gap: 12rpx;
}
.picker-card-left {
  display: flex; flex-direction: column; gap: 8rpx; flex: 1; min-width: 0;
}
.picker-card-header-row {
  display: flex; align-items: center; gap: 12rpx;
}
.picker-card-name {
  font-size: 28rpx; font-weight: 700; color: #0b1c30;
  line-height: 1.2;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  flex-shrink: 1;
}
.picker-card-tag {
  font-size: 18rpx; font-weight: 700; padding: 2rpx 14rpx;
  border-radius: 9999rpx; line-height: 1.6; flex-shrink: 0;
}
.tag-strength  { color: #2563eb; background: #eff6ff; }
.tag-shape     { color: #9333ea; background: #faf5ff; }
.tag-hypertrophy { color: #dc2626; background: #fef2f2; }
.tag-compound  { color: #ea580c; background: #fff7ed; }
.tag-endurance { color: #16a34a; background: #f0fdf4; }
.tag-rehab     { color: #0891b2; background: #ecfeff; }

.picker-card-part {
  font-size: 20rpx; font-weight: 500; color: var(--color-primary);
  background: rgba(34,197,94,0.06); padding: 2rpx 12rpx;
  border-radius: 9999rpx; align-self: flex-start;
}
.picker-card-params {
  display: flex; align-items: center; gap: 4rpx; flex-wrap: wrap;
}
.param-chip {
  font-size: 20rpx; font-weight: 500; color: #64748b;
  background: #fff; padding: 2rpx 12rpx; border-radius: 9999rpx;
  line-height: 1.5;
}
.param-divider {
  font-size: 18rpx; color: #cbd5e1; font-weight: 400; margin: 0 2rpx;
}
.picker-card-add {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  background: var(--color-primary); flex-shrink: 0;
  color: #fff; font-size: 28rpx; font-weight: 600;
  display: flex; align-items: center; justify-content: center;
  line-height: 1;
  box-shadow: 0 4rpx 12rpx rgba(34,197,94,0.25);
}

/* 空列表 */
.picker-empty {
  padding: 80rpx 0; text-align: center;
}
.picker-empty-text {
  font-size: 28rpx; color: #94a3b8;
}
