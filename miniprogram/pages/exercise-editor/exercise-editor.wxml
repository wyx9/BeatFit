<!-- 模板编辑页 -->
<view class="page">
  <!-- Header -->
  <view class="header" style="padding-top: {{statusBarHeight}}px;">
    <view class="header-inner">
      <view class="header-left">
        <image class="header-back" src="/images/icon-arrow-back.svg" mode="aspectFit" bindtap="goBack" />
        <text class="header-title">{{readonly ? '查看模板' : (tplId ? '编辑模板' : '新建模板')}}</text>
      </view>
      <view class="header-save" wx:if="{{!readonly}}" bindtap="onSave">
        <text class="save-text">保存</text>
      </view>
    </view>
  </view>

  <view class="main">
    <!-- 模板名称 -->
    <view class="section">
      <text class="section-label">模板名称</text>
      <input class="name-input" placeholder="输入模板名称..." placeholder-class="name-placeholder" value="{{tplName}}" bindinput="onNameInput" />
    </view>

    <!-- 已选动作列表 -->
    <view class="section">
      <view class="section-header-row">
        <text class="section-label">已选动作 ({{exercises.length}})</text>
      </view>

      <view class="exercise-list" wx:if="{{exercises.length > 0}}">
        <view class="exercise-card" wx:for="{{exercises}}" wx:key="index">
          <image wx:if="{{item.imageUrl}}" class="card-thumb" src="{{item.imageUrl}}" mode="aspectFill" />
          <view wx:else class="card-thumb card-thumb-placeholder">
            <text class="card-thumb-emoji">🏋️</text>
          </view>
          <view class="card-body">
            <view class="card-header">
              <view class="card-title-row">
                <text class="card-name">{{item.name}}</text>
                <text class="card-tag">{{item.tag}}</text>
              </view>
              <image wx:if="{{!readonly}}" class="card-remove" src="/images/icon-close.svg" mode="aspectFit" bindtap="onRemoveExercise" data-index="{{index}}" />
            </view>
            <view class="card-inputs">
              <view class="card-field">
                <text class="field-label">组数</text>
                <input wx:if="{{!readonly}}" class="field-input" type="number" value="{{item.sets}}" bindinput="onParamChange" data-index="{{index}}" data-field="sets" />
                <text wx:else class="field-value">{{item.sets}}</text>
              </view>
              <view class="card-field">
                <text class="field-label">次数</text>
                <input wx:if="{{!readonly}}" class="field-input" type="number" value="{{item.reps}}" bindinput="onParamChange" data-index="{{index}}" data-field="reps" />
                <text wx:else class="field-value">{{item.reps}}</text>
              </view>
              <view class="card-field">
                <text class="field-label">动作时长(秒)</text>
                <input wx:if="{{!readonly}}" class="field-input" type="number" value="{{item.duration_sec}}" bindinput="onParamChange" data-index="{{index}}" data-field="duration_sec" />
                <text wx:else class="field-value">{{item.duration_sec}}s</text>
              </view>
              <view class="card-field">
                <text class="field-label">休息时长(秒)</text>
                <input wx:if="{{!readonly}}" class="field-input" type="number" value="{{item.rest_sec}}" bindinput="onParamChange" data-index="{{index}}" data-field="rest_sec" />
                <text wx:else class="field-value">{{item.rest_sec}}s</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:else>
        <text class="empty-text">暂无动作，点击下方按钮添加</text>
      </view>

      <!-- 添加动作按钮 -->
      <view wx:if="{{!readonly}}" class="add-btn" bindtap="onShowPicker">
        <image class="add-icon" src="/images/icon-add.svg" mode="aspectFit" />
        <text class="add-text">添加动作</text>
      </view>
    </view>
  </view>

  <!-- 底部另存为按钮（只读模式） -->
  <view wx:if="{{readonly}}" class="bottom-bar">
    <view class="bottom-bar-inner">
      <view class="btn-save-as" hover-class="btn-save-as-pressed" bindtap="onSaveAs">
        <text class="btn-save-as-text">另存为我的模板</text>
      </view>
    </view>
  </view>

  <!-- 动作选择器弹窗 -->
  <view class="modal-mask" wx:if="{{showPicker}}" bindtap="onHidePicker">
    <view class="modal-card" catchtap="noop">
      <view class="modal-header">
        <text class="modal-title">选择动作</text>
        <text class="modal-subtitle">{{isSearching ? '全库搜索' : activePickerPartName}} · {{pickerExercises.length}}个动作</text>
        <image class="modal-close" src="/images/icon-close.svg" mode="aspectFit" bindtap="onHidePicker" />
      </view>

      <!-- 搜索栏 -->
      <view class="search-bar">
        <text class="search-icon-emoji">🔍</text>
        <input
          class="search-input"
          placeholder="搜索动作名称…"
          placeholder-class="search-placeholder"
          value="{{pickerSearch}}"
          bindinput="onPickerSearchInput"
          confirm-type="search"
        />
        <view wx:if="{{pickerSearch.length > 0}}" class="search-clear" bindtap="onClearSearch">
          <text class="search-clear-text">✕</text>
        </view>
      </view>

      <!-- 部位 Tab（非搜索模式） -->
      <scroll-view wx:if="{{!isSearching}}" class="picker-tabs" scroll-x enable-flex enhanced show-scrollbar="{{false}}">
        <view
          class="picker-tab {{activePickerPart === item.key ? 'picker-tab-active' : ''}}"
          wx:for="{{pickerParts}}"
          wx:key="key"
          bindtap="onSwitchPickerPart"
          data-key="{{item.key}}"
        >
          <text class="picker-tab-emoji">{{item.icon}}</text>
          <text class="picker-tab-name">{{item.name}}</text>
        </view>
      </scroll-view>

      <!-- 动作卡片列表 -->
      <scroll-view class="picker-list" scroll-y enhanced show-scrollbar="{{false}}">
        <view
          class="picker-card {{item._added ? 'picker-card-added' : ''}}"
          wx:for="{{pickerExercises}}"
          wx:key="name"
          bindtap="{{item._added ? '' : 'onSelectExercise'}}"
          data-name="{{item.name}}"
          data-partkey="{{item._partKey}}"
          hover-class="{{item._added ? '' : 'picker-card-hover'}}"
        >
          <!-- 左侧缩略图 -->
          <image wx:if="{{item.image}}" class="picker-card-thumb" src="{{item.image}}" mode="aspectFill" />
          <view wx:else class="picker-card-thumb picker-card-thumb-placeholder">
            <text class="picker-card-thumb-emoji">{{item.emoji || '🏋️'}}</text>
          </view>

          <!-- 右侧信息 -->
          <view class="picker-card-body">
            <view class="picker-card-left">
              <view class="picker-card-header-row">
                <text class="picker-card-name">{{item.name}}</text>
                <text class="picker-card-tag {{item.tag === '力量' ? 'tag-strength' : item.tag === '塑形' ? 'tag-shape' : item.tag === '肥大' ? 'tag-hypertrophy' : item.tag === '复合' ? 'tag-compound' : item.tag === '耐力' ? 'tag-endurance' : 'tag-rehab'}}">{{item.tag}}</text>
              </view>
              <text wx:if="{{isSearching}}" class="picker-card-part">{{item._part}}</text>
              <view class="picker-card-params" wx:else>
                <text class="param-chip">{{item.sets}}组 × {{item.reps}}次</text>
                <text class="param-divider">·</text>
                <text class="param-chip">{{item.duration_sec}}s / {{item.rest_sec}}s</text>
              </view>
            </view>
            <!-- 添加/已添加按钮 -->
            <view wx:if="{{item._added}}" class="picker-card-added-icon">✓</view>
            <text wx:else class="picker-card-add">＋</text>
          </view>
        </view>

        <!-- 搜索空结果 -->
        <view wx:if="{{isSearching && pickerExercises.length === 0}}" class="picker-empty">
          <text class="picker-empty-text">未找到匹配 "{{pickerSearch}}" 的动作</text>
        </view>
        <!-- 部位空结果 -->
        <view wx:elif="{{!isSearching && pickerExercises.length === 0}}" class="picker-empty">
          <text class="picker-empty-text">该部位暂无动作</text>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
