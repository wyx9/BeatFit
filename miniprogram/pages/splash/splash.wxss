/* ===== 启动页 - 1:1 还原 _3/code.html ===== */

.splash-page {
  position: fixed;
  inset: 0;
  overflow: hidden;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* === Background Blobs === */
.bg-blob {
  position: fixed;
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
}

.bg-blob-top {
  top: -10%;
  right: -10%;
  width: 60%;
  height: 40%;
  background: rgba(34, 197, 94, 0.05);
  filter: blur(240rpx);
}

.bg-blob-bottom {
  bottom: -10%;
  left: -10%;
  width: 50%;
  height: 50%;
  background: rgba(240, 242, 245, 0.2);
  filter: blur(200rpx);
}

/* === Main Content === */
.splash-main {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
  padding: 264rpx 40rpx 64rpx;
  max-width: 640rpx;
  width: 100%;
  box-sizing: border-box;
}

/* === Branding === */
.branding {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  margin-bottom: auto;
  animation: fadeSlideIn 1s ease-out;
}

.logo-wrap {
  margin-bottom: 48rpx;
}

.logo-circle {
  width: 192rpx;
  height: 192rpx;
  background: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  box-shadow: 0 16rpx 48rpx rgba(34, 197, 94, 0.2);
  position: relative;
  overflow: hidden;
}

.logo-shine {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.2), transparent);
  opacity: 0.5;
}

.logo-icon {
  width: 96rpx;
  height: 96rpx;
  position: relative;
  z-index: 10;
}

.logo-pulse {
  position: absolute;
  inset: 0;
  border: 4rpx solid rgba(34, 197, 94, 0.2);
  border-radius: 50%;
  animation: pulseRing 3s infinite ease-in-out;
}

@keyframes pulseRing {
  0%   { transform: scale(0.95); opacity: 0.5; }
  50%  { transform: scale(1.05); opacity: 0.3; }
  100% { transform: scale(0.95); opacity: 0.5; }
}

.brand-title {
  font-size: 80rpx;
  line-height: 96rpx;
  font-weight: 700;
  letter-spacing: -0.02em;
  color: #111827;
  margin-bottom: 8rpx;
}

.brand-subtitle {
  font-size: 32rpx;
  line-height: 48rpx;
  color: #5b5f61;
  max-width: 480rpx;
}

/* === Hero Visual === */
.hero-visual {
  margin-bottom: 64rpx;
  animation: fadeZoomIn 0.7s 0.3s both ease-out;
}

@keyframes fadeZoomIn {
  from { opacity: 0; transform: scale(0.95); }
  to   { opacity: 1; transform: scale(1); }
}

.hero-img-wrap {
  position: relative;
  width: 100%;
  aspect-ratio: 16/9;
  border-radius: 64rpx;
  overflow: hidden;
  box-shadow: 0 24rpx 64rpx rgba(34, 197, 94, 0.1);
  border: 1rpx solid rgba(248, 249, 255, 0.5);
}

.hero-img-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #22c55e, #16a34a);
  position: relative;
}

.hero-img {
  width: 100%;
  height: 100%;
  opacity: 0.3;
}

.hero-gradient {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.5), transparent, transparent);
}

.hero-overlay-content {
  position: absolute;
  bottom: 32rpx;
  left: 32rpx;
  right: 32rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.hero-avatars {
  display: flex;
  margin-right: -32rpx;
}

.hero-avatar-item {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  background: #f8fafc;
  overflow: hidden;
  margin-right: -16rpx;
}

.hero-avatar-img {
  width: 100%;
  height: 100%;
}

.hero-members {
  font-size: 24rpx;
  font-weight: 500;
  color: #fff;
}

/* === Actions === */
.actions {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  margin-bottom: 48rpx;
  width: 100%;
  animation: fadeSlideUp 1s 0.5s both ease-out;
}

@keyframes fadeSlideUp {
  from { opacity: 0; transform: translateY(48rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

.btn-wechat {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  width: 100%;
  height: 112rpx;
  background: var(--color-primary);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 9999rpx;
  box-shadow: 0 16rpx 48rpx rgba(34, 197, 94, 0.25);
  transition: all 0.2s;
  position: relative;
  overflow: hidden;
}

.btn-wechat-pressed {
  transform: scale(0.96);
}

.btn-wechat-text {
  position: relative;
  z-index: 2;
}

.btn-wechat-icon {
  width: 40rpx;
  height: 40rpx;
  position: relative;
  z-index: 2;
}

.btn-guest {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 112rpx;
  background: #fff;
  border: 2rpx solid rgba(226, 232, 240, 0.2);
  border-radius: 9999rpx;
  transition: all 0.2s;
  position: relative;
  overflow: hidden;
}

.btn-guest-pressed {
  transform: scale(0.96);
  border-color: rgba(34, 197, 94, 0.3);
}

.btn-guest-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #454747;
  position: relative;
  z-index: 2;
}

/* === Legal === */
.legal {
  text-align: center;
  animation: fadeSlideIn 1s 0.7s both ease-out;
}

.legal-text {
  font-size: 24rpx;
  line-height: 36rpx;
  color: rgba(91, 95, 97, 0.6);
}

.legal-link {
  color: var(--color-primary);
  font-weight: 500;
}

@keyframes fadeSlideIn {
  from { opacity: 0; transform: translateY(-20rpx); }
  to   { opacity: 1; transform: translateY(0); }
}
