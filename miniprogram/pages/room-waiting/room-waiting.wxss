/* ===== 房间等待页 ===== */
.header {
  position: fixed; top: 0; width: 100%; z-index: 50;
  background: transparent;
  border-bottom: 1rpx solid rgba(226,232,240,0.3);
}
.header-inner {
  display: flex; justify-content: space-between; align-items: center;
  height: 88rpx; padding: 0 40rpx;
}
.header-back { width: 44rpx; height: 44rpx; }
.header-title { font-size: 36rpx; font-weight: 700; color: #131313; }
.header-spacer { width: 44rpx; }

.main {
  padding-top: 168rpx; padding-bottom: 80rpx;
  padding-left: 40rpx; padding-right: 40rpx;
}

/* === 邀请码 === */
.invite-section {
  background: linear-gradient(135deg, rgba(34,197,94,0.08), rgba(34,197,94,0.02));
  border: 2rpx solid rgba(34,197,94,0.15);
  border-radius: 48rpx; padding: 48rpx;
  display: flex; flex-direction: column; align-items: center;
  margin-bottom: 48rpx;
}
.invite-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.invite-label { font-size: 28rpx; font-weight: 600; color: #454747; }
.status-badge {
  font-size: 22rpx; font-weight: 700; padding: 6rpx 20rpx; border-radius: 9999rpx;
}
.status-1 { background: #fbbf24; color: #92400e; }
.status-2 { background: var(--color-primary); color: #fff; }
.status-0 { background: #e5e7eb; color: #6b7280; }
.invite-hint { font-size: 24rpx; color: #94a3b8; margin-bottom: 32rpx; }
.invite-code-row { display: flex; gap: 24rpx; }
/* === 成员列表 === */
.members-section { margin-bottom: 48rpx; }
.section-label { font-size: 28rpx; font-weight: 700; color: #131313; margin-bottom: 20rpx; }
.member-list { display: flex; flex-wrap: wrap; gap: 16rpx; }
.member-item { display: flex; align-items: center; gap: 12rpx; background: #f8f9ff; border-radius: 9999rpx; padding: 12rpx 28rpx 12rpx 12rpx; }
.member-avatar-wrap { width: 56rpx; height: 56rpx; border-radius: 50%; overflow: hidden; flex-shrink: 0; }
.member-avatar { width: 100%; height: 100%; }
.member-avatar-placeholder { width: 100%; height: 100%; background: linear-gradient(135deg, #22c55e, #16a34a); display: flex; align-items: center; justify-content: center; border-radius: 50%; }
.member-avatar-placeholder text { font-size: 24rpx; font-weight: 700; color: #fff; }
.member-name { font-size: 26rpx; font-weight: 600; color: #131313; }
.member-badge { font-size: 20rpx; font-weight: 700; color: var(--color-primary); background: rgba(34,197,94,0.08); padding: 2rpx 14rpx; border-radius: 9999rpx; }

.code-box {
  width: 120rpx; height: 140rpx;
  background: #fff; border: 4rpx solid rgba(34,197,94,0.3);
  border-radius: 32rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 56rpx; font-weight: 700; color: var(--color-primary);
  box-shadow: 0 4rpx 20rpx rgba(34,197,94,0.08);
}

/* === 训练内容 === */
.exercises-section { margin-bottom: 48rpx; }
.section-label {
  font-size: 32rpx; font-weight: 700; color: #131313;
  margin-bottom: 24rpx;
}
.category-block {
  background: #fff; border: 2rpx solid rgba(226,232,240,0.3);
  border-radius: 40rpx; padding: 32rpx; margin-bottom: 24rpx;
}
.cat-name {
  font-size: 28rpx; font-weight: 700; color: var(--color-primary);
  margin-bottom: 24rpx; padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(226,232,240,0.4);
}
.ex-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(226,232,240,0.2);
}
.ex-row:last-child { border-bottom: none; }
.ex-left { display: flex; align-items: center; gap: 16rpx; }
.ex-name { font-size: 28rpx; font-weight: 600; color: #131313; }
.ex-tag {
  font-size: 20rpx; font-weight: 700; color: var(--color-primary);
  background: rgba(34,197,94,0.08); padding: 2rpx 16rpx; border-radius: 9999rpx;
}
.ex-detail { font-size: 22rpx; color: #94a3b8; }

/* === 房间信息 === */
.room-info {
  background: #f8f9ff; border-radius: 40rpx;
  padding: 32rpx 40rpx; margin-bottom: 48rpx;
}
.info-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(226,232,240,0.3);
}
.info-row:last-child { border-bottom: none; }
.info-label { font-size: 26rpx; color: #94a3b8; font-weight: 500; }
.info-value { font-size: 26rpx; font-weight: 600; color: #131313; }
.info-status { color: var(--color-primary); }
.info-expire { color: #fb923c; font-size: 24rpx; }

/* === 操作按钮 === */
.actions { display: flex; gap: 24rpx; }
.btn-dissolve {
  flex: 1; height: 104rpx; border-radius: 9999rpx;
  background: #fff; border: 3rpx solid rgba(239,68,68,0.3);
  display: flex; align-items: center; justify-content: center;
}
.btn-dissolve-pressed { transform: scale(0.96); background: rgba(239,68,68,0.04); }
.btn-dissolve-text { font-size: 30rpx; font-weight: 700; color: #ef4444; }

.btn-start {
  flex: 2; height: 104rpx; border-radius: 9999rpx;
  background: var(--color-primary);
  display: flex; align-items: center; justify-content: center; gap: 16rpx;
  box-shadow: 0 8rpx 30rpx rgba(34,197,94,0.3);
  position: relative; overflow: hidden;
}
.btn-start-pressed { transform: scale(0.96); }
.btn-start-icon { width: 40rpx; height: 40rpx; position: relative; z-index: 2; }
.btn-start-text { font-size: 30rpx; font-weight: 700; color: #fff; position: relative; z-index: 2; }

/* === 等待提示（非房主） === */
.waiting-hint {
  text-align: center; padding: 48rpx 0;
}
.waiting-text {
  font-size: 30rpx; color: #94a3b8; font-weight: 500;
}
