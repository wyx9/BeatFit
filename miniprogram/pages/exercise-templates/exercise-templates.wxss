/* ===== 模板管理页（动作库） ===== */

/* Page fade-in for smooth tab transitions */
.page {
  animation: pageFadeIn 0.2s ease both;
}
@keyframes pageFadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

/* === Page Title === */
.page-title {
  font-size: 44rpx; font-weight: 700; color: #0b1c30;
  margin-bottom: 40rpx; padding-left: 4rpx;
}

/* === Main === */
.main {
  padding-top: 60rpx; padding-bottom: 200rpx;
  padding-left: 40rpx; padding-right: 40rpx;
  max-width: 900rpx; margin: 0 auto;
}

/* === Section === */
.section { margin-bottom: 56rpx; }
.section-header {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 24rpx;
}
.section-title {
  display: block; font-size: 32rpx; font-weight: 700; color: #0b1c30;
  margin-bottom: 24rpx;
}
.section-header .section-title { margin-bottom: 0; }
.section-action {
  display: flex; align-items: center; gap: 4rpx;
}
.action-icon { width: 36rpx; height: 36rpx; }
.action-text { font-size: 26rpx; font-weight: 600; color: var(--color-primary); }

/* === Template Cards === */
.tpl-grid { display: flex; flex-direction: column; gap: 24rpx; }
.tpl-card {
  background: #fff; border: 2rpx solid #f3f4f6;
  border-radius: 64rpx; padding: 48rpx;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.05);
}
.tpl-card-top {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 20rpx;
}
.tpl-card-info { display: flex; flex-direction: column; gap: 6rpx; }
.tpl-card-name { font-size: 30rpx; font-weight: 700; color: #0b1c30; }
.tpl-card-count { font-size: 24rpx; color: #94a3b8; }
.tpl-card-arrow { font-size: 32rpx; color: #94a3b8; }

.tpl-card-tags { display: flex; flex-wrap: wrap; gap: 12rpx; }
.tpl-tag {
  font-size: 22rpx; font-weight: 500; color: #565e74;
  background: #f1f5f9; padding: 6rpx 20rpx; border-radius: 9999rpx;
}

/* === User Template Card Extra === */
.tpl-card-user { border-color: rgba(188,203,185,0.15); }
.tpl-card-actions {
  margin-top: 24rpx; padding-top: 20rpx;
  border-top: 1rpx solid #f1f5f9;
  display: flex; justify-content: flex-end;
}
.action-delete {
  font-size: 24rpx; font-weight: 500; color: #ef4444;
  padding: 8rpx 24rpx;
}

/* === Empty State === */
.empty-section { display: flex; flex-direction: column; gap: 32rpx; }
.empty-state {
  display: flex; flex-direction: column; align-items: center;
  padding: 80rpx 40rpx;
  border: 4rpx dashed rgba(188,203,185,0.3);
  border-radius: 32rpx;
}
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-title { font-size: 28rpx; font-weight: 600; color: #3d4a3d; margin-bottom: 8rpx; }
.empty-desc { font-size: 24rpx; color: #94a3b8; }

/* === New Button === */
.btn-new {
  width: 100%; height: 112rpx; background: var(--color-primary);
  border-radius: 9999rpx; display: flex; align-items: center; justify-content: center;
  gap: 12rpx; box-shadow: 0 8rpx 30rpx rgba(34,197,94,0.3);
}
.btn-new-pressed { transform: scale(0.98); opacity: 0.9; }
.btn-new-icon { font-size: 40rpx; font-weight: 300; color: #fff; }
.btn-new-text { font-size: 34rpx; font-weight: 700; color: #fff; }

/* === Bottom Navigation === */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  z-index: 50;
  display: flex;
  justify-content: space-around;
  align-items: center;
  gap: 0;
  padding: 24rpx 40rpx calc(56rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-top: 1rpx solid rgba(226, 232, 240, 0.3);
  box-shadow: 0 -16rpx 60rpx rgba(0, 0, 0, 0.02);
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  color: #454747;
  transition: all 0.2s;
}

.nav-active {
  color: var(--color-primary);
}

.nav-icon {
  width: 48rpx;
  height: 48rpx;
}

.nav-label {
  font-size: 22rpx;
  font-weight: 700;
  margin-top: 2rpx;
  color: #454747;
}

.nav-label-active {
  color: var(--color-primary);
}
